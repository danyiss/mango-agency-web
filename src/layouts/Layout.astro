---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, getLocalizedPath, type Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  lang?: Lang;
  ogImage?: string;
  transparentTop?: boolean;
}

const currentLang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const altLang = currentLang === 'en' ? 'es' : 'en';

const { title, description = t('home.hero.subtitle'), activeNav = '', ogImage = '/og-image.png', transparentTop = false } = Astro.props;
const currentYear = new Date().getFullYear();

// Canonical and alternate URLs
const siteUrl = 'https://www.mangova.agency';
const basePath = Astro.url.pathname.replace(/^\/(es|en)/, '').replace(/\/$/, '') || '/';
const canonicalUrl = `${siteUrl}${Astro.url.pathname.replace(/\/$/, '') || '/'}`;
const altUrl = altLang === 'en' ? basePath : `/es${basePath === '/' ? '' : basePath}`;
const altFullUrl = `${siteUrl}${altUrl}`;
const ogImageUrl = `${siteUrl}${ogImage}`;

function localPath(path: string) {
  return getLocalizedPath(path, currentLang);
}

// Organization schema (on every page)
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "MANGO Agency",
  "alternateName": "Mangova Agency",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.svg`,
  "description": "System-driven talent management agency for content creators. Strategy, chatting, marketing, and operations infrastructure.",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "hello@mangova.agency",
    "contactType": "sales"
  },
  "sameAs": [
    "https://instagram.com/mango.creators"
  ]
};
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={currentLang} href={canonicalUrl} />
    <link rel="alternate" hreflang={altLang} href={altFullUrl} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${basePath}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={currentLang === 'en' ? 'en_US' : 'es_ES'} />
    <meta property="og:locale:alternate" content={altLang === 'en' ? 'en_US' : 'es_ES'} />
    <meta property="og:site_name" content="MANGO Agency" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- Extra head slot for page-specific schema -->
    <slot name="head" />
  </head>
  <body class="bg-surface text-on-surface font-body antialiased">
    <!-- Navigation -->
    <header class={`fixed top-0 left-0 right-0 z-50 glass-nav${transparentTop ? '' : ' scrolled'}`} data-transparent-top={transparentTop ? 'true' : 'false'}>
      <div class="px-4 sm:px-6 md:px-8 lg:px-10 h-16 flex items-center justify-between">
        <a href={localPath('/')} class="flex items-center" aria-label="MANGO Talent Management">
          <img src="/logo.png" alt="MANGO Talent Management" class="nav-logo h-6 md:h-7 w-auto" />
        </a>
        <nav class="hidden md:flex items-center gap-6">
          <a href={localPath('/')} class="nav-link text-sm font-medium">{t('nav.home')}</a>
          <a href={localPath('/results')} class="nav-link text-sm font-medium">{t('nav.results')}</a>
          <a href={localPath('/how-it-works')} class="nav-link text-sm font-medium">{t('nav.howItWorks')}</a>
          <a href={localPath('/for-agencies')} class="nav-link text-sm font-medium">{t('nav.forAgencies')}</a>
        </nav>
        <div class="flex items-center gap-3 md:gap-4">
          <a href={altUrl} class="nav-link text-xs font-semibold uppercase tracking-wider">
            {altLang === 'en' ? 'EN' : 'ES'}
          </a>
          <a href="#apply" class="hidden sm:inline-block bg-accent text-black px-5 py-2 text-sm font-bold rounded-[7px] hover:brightness-95 hover:scale-[1.02] transition-all">
            {t('nav.applyNow')}
          </a>
          <button id="mobile-menu-btn" class="md:hidden nav-link p-2 -mr-2" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
            <span class="material-symbols-outlined text-[26px] block" aria-hidden="true">menu</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-[60] bg-white hidden flex-col opacity-0 transition-opacity duration-200" role="dialog" aria-modal="true" aria-label="Navigation">
      <div class="h-16 px-4 sm:px-6 flex items-center justify-between border-b border-outline-variant/20">
        <a href={localPath('/')} class="flex items-center" aria-label="MANGO Talent Management">
          <img src="/logo.png" alt="MANGO Talent Management" class="h-6 w-auto" />
        </a>
        <button id="mobile-menu-close" class="p-2 -mr-2 text-on-surface" aria-label="Close menu">
          <span class="material-symbols-outlined text-[26px] block" aria-hidden="true">close</span>
        </button>
      </div>
      <nav class="flex-1 px-6 py-10 flex flex-col gap-6">
        <a href={localPath('/')} class="text-3xl font-black text-on-surface tracking-tight">{t('nav.home')}</a>
        <a href={localPath('/results')} class="text-3xl font-black text-on-surface tracking-tight">{t('nav.results')}</a>
        <a href={localPath('/how-it-works')} class="text-3xl font-black text-on-surface tracking-tight">{t('nav.howItWorks')}</a>
        <a href={localPath('/for-agencies')} class="text-3xl font-black text-on-surface tracking-tight">{t('nav.forAgencies')}</a>
        <a href={altUrl} class="mt-2 text-xs font-semibold text-outline uppercase tracking-widest">
          {altLang === 'en' ? 'Switch to English' : 'Cambiar a Espa\u00f1ol'}
        </a>
      </nav>
      <div class="p-6 border-t border-outline-variant/20">
        <a href="#apply" class="block text-center bg-accent text-black font-bold py-4 rounded-[7px] text-sm tracking-wide hover:brightness-95 hover:scale-[1.02] transition-all" data-close-menu>
          {t('nav.applyNow')}
        </a>
      </div>
    </div>
    <script is:inline>
      (function(){
        const nav = document.querySelector('.glass-nav');
        if (nav && nav.dataset.transparentTop === 'true') {
          function sync(){
            if (window.scrollY > 20) nav.classList.add('scrolled');
            else nav.classList.remove('scrolled');
          }
          sync();
          window.addEventListener('scroll', sync, { passive: true });
        }

        const menu = document.getElementById('mobile-menu');
        const btnOpen = document.getElementById('mobile-menu-btn');
        const btnClose = document.getElementById('mobile-menu-close');
        if (!menu || !btnOpen || !btnClose) return;
        function open(){
          menu.classList.remove('hidden');
          menu.classList.add('flex');
          requestAnimationFrame(() => menu.classList.replace('opacity-0', 'opacity-100'));
          document.body.style.overflow = 'hidden';
          btnOpen.setAttribute('aria-expanded', 'true');
        }
        function close(){
          menu.classList.replace('opacity-100', 'opacity-0');
          setTimeout(() => {
            menu.classList.add('hidden');
            menu.classList.remove('flex');
          }, 200);
          document.body.style.overflow = '';
          btnOpen.setAttribute('aria-expanded', 'false');
        }
        btnOpen.addEventListener('click', open);
        btnClose.addEventListener('click', close);
        // Close when any nav link inside menu is clicked
        menu.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
        document.addEventListener('keydown', e => { if (e.key === 'Escape' && !menu.classList.contains('hidden')) close(); });
      })();
    </script>

    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="py-12 bg-white border-t border-outline-variant/20">
      <div class="px-4 sm:px-6 md:px-8 lg:px-10 flex flex-col md:flex-row justify-between items-center gap-6">
        <a href={localPath('/')} class="flex items-center" aria-label="MANGO Talent Management">
          <img src="/logo.png" alt="MANGO Talent Management" class="h-7 w-auto" />
        </a>
        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8">
          <div class="flex items-center gap-6 md:gap-8 text-sm text-secondary font-medium">
            <a class="hover:text-primary transition-colors" href={localPath('/legal')}>{t('footer.privacy')}</a>
            <a class="hover:text-primary transition-colors" href={localPath('/legal')}>{t('footer.terms')}</a>
            <a
              href="https://instagram.com/mango.creators"
              target="_blank"
              rel="noopener"
              aria-label="Instagram"
              class="inline-flex items-center justify-center text-secondary hover:text-primary transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
              </svg>
            </a>
          </div>
          <p class="text-xs text-outline font-medium">&copy; {currentYear} {t('footer.copyright')}</p>
        </div>
      </div>
    </footer>
  </body>
</html>
