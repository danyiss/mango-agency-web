---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, getLocalizedPath, type Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  lang?: Lang;
}

const currentLang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const altLang = currentLang === 'en' ? 'es' : 'en';

const { title, description = t('home.hero.subtitle'), activeNav = '' } = Astro.props;
const currentYear = new Date().getFullYear();

// Build localized paths
const basePath = Astro.url.pathname.replace(/^\/(es|en)/, '').replace(/\/$/, '') || '/';
const altUrl = altLang === 'en' ? basePath : `/es${basePath === '/' ? '' : basePath}`;

function localPath(path: string) {
  return getLocalizedPath(path, currentLang);
}
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang={altLang} href={altUrl} />
    <link rel="alternate" hreflang={currentLang} href={Astro.url.pathname} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-on-surface font-body antialiased">
    <!-- Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 glass-nav border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={localPath('/')} class="text-xl font-black tracking-tighter text-primary">MANGO</a>
        <nav class="hidden md:flex items-center gap-6">
          <a href={localPath('/')} class:list={["text-sm font-medium transition-colors", activeNav === 'home' ? 'text-primary font-semibold border-b-2 border-primary pb-1' : 'text-secondary hover:text-primary']}>{t('nav.home')}</a>
          <a href={localPath('/results')} class:list={["text-sm font-medium transition-colors", activeNav === 'results' ? 'text-primary font-semibold border-b-2 border-primary pb-1' : 'text-secondary hover:text-primary']}>{t('nav.results')}</a>
          <a href={localPath('/how-it-works')} class:list={["text-sm font-medium transition-colors", activeNav === 'how-it-works' ? 'text-primary font-semibold border-b-2 border-primary pb-1' : 'text-secondary hover:text-primary']}>{t('nav.howItWorks')}</a>
          <a href={localPath('/for-agencies')} class:list={["text-sm font-medium transition-colors", activeNav === 'for-agencies' ? 'text-primary font-semibold border-b-2 border-primary pb-1' : 'text-secondary hover:text-primary']}>{t('nav.forAgencies')}</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href={altUrl} class="text-xs font-semibold text-secondary hover:text-primary transition-colors uppercase tracking-wider">
            {altLang === 'en' ? 'EN' : 'ES'}
          </a>
          <a href="#apply" class="bg-primary text-on-primary px-5 py-2 text-sm font-bold rounded-lg hover:bg-primary-container transition-all">
            {t('nav.applyNow')}
          </a>
        </div>
      </div>
    </header>

    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="py-12 bg-white border-t border-outline-variant/20 px-6">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
        <a href={localPath('/')} class="text-2xl font-black tracking-tighter text-primary">MANGO</a>
        <div class="flex gap-8 text-sm text-secondary font-medium">
          <a class="hover:text-primary transition-colors" href={localPath('/legal')}>{t('footer.privacy')}</a>
          <a class="hover:text-primary transition-colors" href={localPath('/legal')}>{t('footer.terms')}</a>
          <a class="hover:text-primary transition-colors" href="https://instagram.com/mangova.agency" target="_blank" rel="noopener">{t('footer.instagram')}</a>
        </div>
        <p class="text-xs text-outline font-medium">&copy; {currentYear} {t('footer.copyright')}</p>
      </div>
    </footer>
  </body>
</html>
