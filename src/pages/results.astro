---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Results | MANGO Agency" activeNav="results" lang="en" transparentTop={true}>

  <!-- 1. HERO -->
  <section class="relative h-screen -mt-16 w-full overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/hero-results.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/20"></div>
    <div class="absolute inset-0 flex items-center">
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-[620px] flex flex-col gap-6">
          <h1 class="text-5xl md:text-7xl font-black text-white tracking-tight leading-[1.1] max-w-[580px]">
            System-driven results<br />
            <span class="text-white/70 text-4xl md:text-6xl font-bold">Not luck</span>
          </h1>
          <p class="text-white/85 text-lg md:text-xl leading-relaxed">
            Predictable revenue.<br />Built on systems.
          </p>
          <div class="border-l-2 border-white/50 pl-5 text-sm md:text-base text-white/70 leading-snug">
            <p>Not virality. Not luck.</p>
            <p>Just structured systems.</p>
          </div>
          <div class="mt-2">
            <a href="/#apply" class="inline-block bg-accent text-black font-bold px-8 py-4 rounded-xl text-sm tracking-wide hover:brightness-95 transition-all shadow-lg">
              Apply now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. FEATURED RESULT -->
  <section class="pt-32 pb-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-5 flex flex-col gap-7">
          <div class="flex items-baseline gap-3 flex-nowrap whitespace-nowrap">
            <span class="text-6xl md:text-8xl font-black text-on-surface tracking-tight leading-none">$24,586</span>
            <span class="text-2xl md:text-3xl font-bold text-on-surface-variant">/month</span>
          </div>
          <p class="text-xl md:text-2xl text-on-surface font-semibold leading-tight">Built through structured monetization systems.</p>
          <p class="text-on-surface-variant text-base leading-relaxed max-w-lg">
            This account was already posting consistently but not converting. We implemented structured chatting, upsells, and retention systems &mdash; and revenue compounded from there.
          </p>
        </div>
        <div class="lg:col-span-7 rounded-2xl overflow-hidden border border-outline-variant/20 shadow-xl aspect-[5/3] bg-white">
          <img src="/assets/results/main-feature-block.jpeg" alt="$24,586 in a single month" class="w-full h-full object-cover object-top block" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 3. RESULTS GRID -->
  <section class="pb-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { value: '$19,025', unit: '/month', text: 'Driven by optimized chatting systems and better monetization.', img: '/assets/results/results-grid1.jpeg' },
          { value: '$13,098', unit: '/month', text: 'Growth achieved by aligning content strategy with conversion systems.', img: '/assets/results/results-grid2.jpeg' },
          { value: '+558%', unit: 'growth', text: 'From inconsistent revenue to structured and predictable income.', img: '/assets/results/results-grid3-v2.jpeg' },
        ].map(card => (
          <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 flex flex-col gap-6">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-5xl md:text-6xl font-black text-on-surface tracking-tight leading-none">{card.value}</span>
              <span class="text-on-surface-variant text-base">{card.unit}</span>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">{card.text}</p>
            <div class="rounded-lg overflow-hidden border border-outline-variant/20 mt-auto aspect-[5/3] bg-white">
              <img src={card.img} alt={card.value} class="w-full h-full object-cover object-top block" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. KEY INSIGHT (BLACK, FULL WIDTH) -->
  <section class="py-40 md:py-52 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-7xl font-black tracking-tight leading-[1.05]">
        Most creators don&rsquo;t have a traffic problem. <span class="text-white/60">They have a monetization problem.</span>
      </h2>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        Traffic without systems doesn&rsquo;t convert. We focus on what actually makes money.
      </p>
    </div>
  </section>

  <!-- 5. DAILY PERFORMANCE -->
  <section class="py-32 bg-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col gap-14 items-center text-center">
        <div>
          <h2 class="text-5xl md:text-7xl font-black text-on-surface tracking-tight leading-[0.95]">Consistent high-performing days</h2>
          <p class="mt-5 text-on-surface-variant text-xl md:text-2xl font-semibold">Revenue spikes driven by structured systems &mdash; not randomness.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block1.jpeg" alt="Single-day earnings over $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block2.jpeg" alt="Single-day earnings over $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FINAL CTA (BLACK) -->
  <section class="py-32 md:py-40 bg-black text-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05]">
        If your page isn&rsquo;t performing like this, there&rsquo;s a reason.
      </h2>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed">
        We&rsquo;ll show you exactly what&rsquo;s missing.
      </p>
      <div>
        <a href="/#apply" class="inline-block bg-accent text-black font-bold px-10 py-5 rounded-xl text-sm tracking-wide hover:brightness-95 transition-all">
          Apply Now
        </a>
      </div>
    </div>
  </section>

</Layout>
