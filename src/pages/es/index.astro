---
import Layout from '../../layouts/Layout.astro';
import ApplyForm from '../../components/ApplyForm.astro';
import { useTranslations } from '../../i18n/translations';

const t = useTranslations('es');

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": t('home.faq.q1'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a1') }},
    { "@type": "Question", "name": t('home.faq.q2'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a2') }},
    { "@type": "Question", "name": t('home.faq.q3'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a3') }},
    { "@type": "Question", "name": t('home.faq.q4'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a4') }},
    { "@type": "Question", "name": t('home.faq.q5'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a5') }},
    { "@type": "Question", "name": t('home.faq.q6'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a6') }},
    { "@type": "Question", "name": t('home.faq.q7'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a7') }},
    { "@type": "Question", "name": t('home.faq.q8'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a8') }},
    { "@type": "Question", "name": t('home.faq.q9'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a9') }},
    { "@type": "Question", "name": t('home.faq.q10'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a10') }},
    { "@type": "Question", "name": t('home.faq.q11'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a11') }},
    { "@type": "Question", "name": t('home.faq.q12'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a12') }},
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Gestion OnlyFans",
  "provider": { "@type": "Organization", "name": "MANGO Agency" },
  "description": "Agencia de gestion de talento para creadoras de contenido. Operaciones de chatting, estrategia de marketing, generacion de trafico y optimizacion operativa.",
  "serviceType": "Agencia de Gestion de Talento",
  "areaServed": ["Europa", "Asia"],
};
---

<Layout title="MANGO | Para Creadores, Por Creadores" activeNav="home" lang="es" transparentTop={true}>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/assets/hero-home.png" type="image/png" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 1. HERO SECTION -->
  <section class="relative h-screen -mt-16 w-full overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/hero-home.png');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/20"></div>
    <div class="absolute inset-0 flex items-center">
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-[620px] flex flex-col gap-6">
          <span class="text-xs font-semibold tracking-[0.25em] uppercase text-white/60">Para creadoras, por creadoras</span>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-white tracking-tight leading-[1.1]">
            <span class="whitespace-nowrap">Escala tu OnlyFans a meses</span><br />de 5&ndash;6 cifras
          </h1>
          <p class="text-white/85 text-lg md:text-xl leading-relaxed">
            Construimos los sistemas detr&aacute;s de las top creadoras &mdash; para que t&uacute; te centres en el contenido mientras nosotros nos encargamos del crecimiento y la monetizaci&oacute;n.
          </p>
          <div class="border-l-2 border-white/50 pl-5 text-sm md:text-base text-white/70 leading-snug">
            <p>T&uacute; te centras en el contenido.</p>
            <p>Nosotros construimos los ingresos.</p>
          </div>
          <div class="mt-2">
            <a href="#apply" class="inline-block bg-accent text-black font-bold px-8 py-4 rounded-[7px] text-sm tracking-wide hover:brightness-95 hover:scale-[1.02] transition-all shadow-lg">
              Aplicar ahora
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-6 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
      <span class="text-xs font-medium tracking-widest uppercase">{t('home.hero.scroll')}</span>
      <span class="material-symbols-outlined animate-bounce">keyboard_arrow_down</span>
    </div>
  </section>

  <!-- 2. STATEMENT SECTION (black) -->
  <section class="py-28 md:py-36 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-[1.15]">
        La mayor&iacute;a de creadores ganan el 20% de lo que podr&iacute;an. <span class="text-white/60">Nosotros arreglamos el otro 80%.</span>
      </h2>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        El problema no suele ser el esfuerzo &mdash; es la falta de sistemas, monetizaci&oacute;n y ejecuci&oacute;n.
      </p>
    </div>
  </section>

  <!-- 3a. RESULTS HEADER + MAIN FEATURE (WHITE) -->
  <section id="results" class="pt-32 pb-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-24">
        <h2 class="text-4xl md:text-6xl font-black text-on-surface tracking-tight leading-[1.05]">Los ingresos son lo &uacute;nico que importa.</h2>
        <p class="mt-5 text-on-surface-variant text-lg">Nos centramos en lo que de verdad hace crecer tu dinero.</p>
      </div>

      <!-- Featured hero proof -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-5 flex flex-col gap-7">
          <div class="flex items-baseline gap-3 flex-nowrap whitespace-nowrap">
            <span class="text-6xl md:text-8xl font-black text-on-surface tracking-tight leading-none">$24,586</span>
            <span class="text-2xl md:text-3xl font-bold text-on-surface-variant">/mes</span>
          </div>
          <p class="text-xl md:text-2xl text-on-surface font-semibold leading-tight">Sin depender de suscripciones.</p>
          <p class="text-on-surface-variant text-base leading-relaxed max-w-lg">
            Antes de trabajar con nosotros, esta cuenta no rend&iacute;a pese a publicar de forma constante. El problema no era el contenido &mdash; era la falta de sistemas de monetizaci&oacute;n.
          </p>
        </div>
        <div class="lg:col-span-7 rounded-2xl overflow-hidden border border-outline-variant/20 shadow-xl aspect-[5/3] bg-white">
          <img src="/assets/results/main-feature-block.jpeg" alt="$24,586 en un solo mes" class="w-full h-full object-cover object-top block" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 3b. RESULTS STACK (WHITE) -->
  <section class="pb-32 bg-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col gap-8">
        {[
          { value: '$19,025', unit: '/mes', text: 'Construido con sistemas de monetizaci\u00f3n consistentes \u2014 no solo tr\u00e1fico.', img: '/assets/results/results-grid1.jpeg' },
          { value: '$13,098', unit: '/mes', text: 'Escalando con contenido estructurado + integraci\u00f3n de chatting.', img: '/assets/results/results-grid2.jpeg' },
          { value: '+558%', unit: 'crecimiento', text: 'De cuenta estancada a ingresos estructurados en semanas.', img: '/assets/results/results-grid3-v2.jpeg' },
        ].map(card => (
          <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 shadow-lg overflow-hidden">
            <div class="p-10 md:p-14 flex flex-col gap-4">
              <div class="flex items-baseline gap-3 flex-wrap">
                <span class="text-7xl md:text-9xl font-black text-on-surface tracking-tight leading-none">{card.value}</span>
                <span class="text-xl md:text-2xl font-bold text-on-surface-variant">{card.unit}</span>
              </div>
              <p class="text-on-surface-variant text-base md:text-lg leading-relaxed max-w-xl">{card.text}</p>
            </div>
            <div class="aspect-[16/7] overflow-hidden border-t border-outline-variant/10">
              <img src={card.img} alt={card.value} class="w-full h-full object-cover object-top block" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3c. INSIGHT BLOCK (BLACK, FULL-WIDTH) -->
  <section class="py-40 md:py-52 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h3 class="text-4xl md:text-7xl font-black tracking-tight leading-[1.05]">La mayor&iacute;a de los ingresos no vienen de las suscripciones.</h3>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        Hasta el 70&ndash;85% viene de DMs, upsells y sistemas estructurados de chatting.
      </p>
    </div>
  </section>

  <!-- 3d. DAILY PERFORMANCE (WHITE) -->
  <section class="py-32 bg-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col gap-14 items-center text-center">
        <div>
          <h3 class="text-5xl md:text-7xl font-black text-on-surface tracking-tight leading-[0.95]">D&iacute;as de $2k+ &mdash; de forma consistente</h3>
          <p class="mt-5 text-on-surface-variant text-xl md:text-2xl font-semibold">No es suerte. Son sistemas.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block1.jpeg" alt="Ingresos de un solo d&iacute;a superiores a $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block2.jpeg" alt="Ingresos de un solo d&iacute;a superiores a $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3e. SYSTEM EXPLANATION (SURFACE) -->
  <section class="py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-20">
        <h3 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">&iquest;Qu&eacute; hay detr&aacute;s de estos resultados?</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { n: '01', title: 'Equipo de chatting dedicado por creadora', text: 'Cada creadora tiene su propio equipo interno entrenado \u2014 no compartido entre docenas.' },
          { n: '02', title: 'Sistemas de venta estructurados', text: 'DMs, upsells y flujos de retenci\u00f3n dise\u00f1ados para maximizar los ingresos por fan.' },
          { n: '03', title: 'An\u00e1lisis semanal de rendimiento', text: 'Analizamos, optimizamos e iteramos cada semana para componer tu crecimiento.' },
        ].map(item => (
          <div class="bg-surface-container-lowest p-10 rounded-xl border border-outline-variant/20 flex flex-col gap-5">
            <span class="text-6xl font-black text-outline-variant/40 leading-none">{item.n}</span>
            <h4 class="text-xl font-bold text-on-surface">{item.title}</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3f. FINAL CTA (BLACK) -->
  <section class="py-32 md:py-40 bg-black text-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h3 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05]">&iquest;Listo para escalar tu OnlyFans as&iacute;?</h3>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed">
        Solo trabajamos con un n&uacute;mero limitado de creadoras para mantener un enfoque cercano y orientado al rendimiento.
      </p>
      <div>
        <a href="#apply" class="inline-block bg-accent text-black font-bold px-10 py-5 rounded-[7px] text-sm tracking-wide hover:brightness-95 hover:scale-[1.02] transition-all">
          Aplicar Ahora
        </a>
      </div>
    </div>
  </section>

  <!-- 4. PROBLEM SECTION -->
  <section class="py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight">Por qu&eacute; est&aacute;s estancado</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">trending_down</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Publicas pero no creces</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">Publicas de forma constante, pero nada se mueve. Sin alcance, sin tracci&oacute;n — porque no tienes un sistema de tr&aacute;fico real detr&aacute;s.</p>
          </div>
        </div>
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">payments</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Tus subs no gastan</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">Tienes suscriptores... pero no compran. Chatting d&eacute;bil, sin estructura, sin estrategia — est&aacute;s dejando dinero en la mesa cada d&iacute;a.</p>
          </div>
        </div>
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">bolt</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Quemado haci&eacute;ndolo todo</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">Contenido, publicaciones, respuestas, planificaci&oacute;n... todo. Sin sistemas, no est&aacute;s escalando — solo trabajas m&aacute;s por los mismos resultados.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SERVICES SECTION -->
  <section class="py-28 bg-surface-container">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1] mb-5">Todo lo que hace crecer tus ingresos &mdash; gestionado por nosotros</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed">Nos encargamos de todo lo que pasa detr&aacute;s &mdash; para que tu p&aacute;gina se convierta en una m&aacute;quina de ingresos constante.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {[
          {
            icon: 'chat',
            title: 'Monetizaci\u00f3n 24/7',
            text: 'Nuestro equipo interno de chatting vende por ti 24/7 &mdash; en ingl\u00e9s y espa\u00f1ol &mdash; con estrategias probadas adaptadas a tu personalidad, para que ganes m\u00e1s sin estar online todo el d\u00eda.',
          },
          {
            icon: 'trending_up',
            title: 'Marketing y Crecimiento',
            text: 'Escalamos tu cuenta con estrategias enfocadas en Instagram, sistemas multi-cuenta y contenido basado en datos &mdash; atrayendo tr\u00e1fico de calidad que convierte en fans que pagan.',
          },
          {
            icon: 'payments',
            title: 'Optimizaci\u00f3n de Ingresos',
            text: 'Optimizamos tu pricing, contenido y flujo de ventas para aumentar cu\u00e1nto gasta cada fan &mdash; convirtiendo tu p\u00e1gina en un flujo de ingresos predecible.',
          },
          {
            icon: 'shield',
            title: 'Protecci\u00f3n DMCA y Leaks',
            text: 'Monitorizamos y eliminamos contenido filtrado proactivamente, protegiendo tus cuentas &mdash; para que tus ingresos sigan seguros mientras creces.',
          },
        ].map(card => (
          <div class="bg-surface-container-lowest p-10 rounded-xl border border-outline-variant/20 hover:shadow-md transition-shadow flex flex-col gap-5">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-on-primary" style="font-size:22px;" set:html={card.icon} />
              </div>
              <h3 class="text-xl font-bold text-on-surface">{card.title}</h3>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed" set:html={card.text}></p>
          </div>
        ))}
      </div>

      <p class="text-center text-on-surface text-lg md:text-xl font-semibold mt-14">
        T&uacute; te centras en crear contenido. Nosotros en todo lo que te hace ganar dinero.
      </p>
    </div>
  </section>

  <!-- 4. WHY TOP CREATORS WORK WITH US -->
  <section class="py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">Por qu&eacute; los mejores creadores trabajan con nosotros</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            icon: 'settings_suggest',
            title: 'Sistemas, no suposiciones',
            text: 'No dependemos de tendencias ni suerte \u2014 conectamos sistemas probados a tu cuenta para generar ingresos constantes.',
          },
          {
            icon: 'groups',
            title: 'Equipo interno, totalmente controlado',
            text: 'Nuestros chatters, managers y equipo de marketing est\u00e1n formados y gestionados internamente \u2014 asegurando consistencia y rendimiento.',
          },
          {
            icon: 'language',
            title: 'Monetizaci\u00f3n en ingl\u00e9s y espa\u00f1ol',
            text: 'Vendemos a una audiencia global con chatting a nivel nativo \u2014 aumentando conversiones y maximizando tus ingresos.',
          },
          {
            icon: 'trending_up',
            title: 'Enfocados en ingresos, no en m\u00e9tricas vanidosas',
            text: 'Nos centramos en cu\u00e1nto ganas y c\u00f3mo aumentarlo cada mes \u2014 no en likes o followers.',
          },
          {
            icon: 'lock_open',
            title: 'Sin contratos a largo plazo',
            text: 'Te quedas porque funciona \u2014 no porque est\u00e9s atado. Ganamos nuestro sitio cada mes.',
          },
          {
            icon: 'tune',
            title: 'Totalmente adaptado a ti',
            text: 'Cada estrategia se ajusta a tu personalidad, contenido y audiencia \u2014 sin enfoques gen\u00e9ricos.',
          },
        ].map(card => (
          <div class="bg-surface-container-lowest p-10 rounded-xl border border-outline-variant/20 hover:shadow-md transition-shadow flex flex-col gap-5">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-on-primary" style="font-size:22px;" set:html={card.icon} />
              </div>
              <h3 class="text-xl font-bold text-on-surface">{card.title}</h3>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">{card.text}</p>
          </div>
        ))}
      </div>

      <p class="text-center text-on-surface text-lg md:text-xl font-semibold mt-14">
        Esto no es gesti&oacute;n. Esto es infraestructura.
      </p>
    </div>
  </section>

  <!-- 5. PROCESS SECTION -->
  <section id="how-it-works" class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight">Qu&eacute; pasa cuando te unes</h2>
        <p class="mt-4 text-on-surface-variant text-lg max-w-xl mx-auto">Un proceso simple y r&aacute;pido para empezar a escalar tus ingresos.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-outline-variant/20">
        {[
          { num: '01', title: 'Evaluaci\u00f3n r\u00e1pida', text: 'Revisamos tu cuenta, contenido y potencial para identificar d\u00f3nde puedes crecer m\u00e1s r\u00e1pido.' },
          { num: '02', title: 'Estrategia y setup', text: 'Construimos un plan personalizado e integramos nuestros sistemas en tu cuenta \u2014 chatting, marketing y monetizaci\u00f3n.' },
          { num: '03', title: 'Activaci\u00f3n completa', text: 'Activamos todos los sistemas de crecimiento y monetizaci\u00f3n en tu cuenta \u2014 listos para escalar desde el primer d\u00eda.' },
          { num: '04', title: 'Escalar y optimizar', text: 'Optimizamos todo continuamente para aumentar tus ingresos mes tras mes.' },
        ].map(step => (
          <div class="flex flex-col gap-4 px-8 py-10">
            <span class="text-7xl font-black text-outline-variant/30 leading-none">{step.num}</span>
            <h3 class="text-xl font-black text-on-surface">{step.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-on-surface text-lg font-semibold mt-14">
        Sin complicaciones. Sin tiempo perdido. Solo crecimiento.
      </p>
    </div>
  </section>

