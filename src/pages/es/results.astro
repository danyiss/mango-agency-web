---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Resultados | MANGO Agency" activeNav="results" lang="es" transparentTop={true}>

  <!-- 1. HERO -->
  <section class="relative h-screen -mt-16 w-full overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/hero-results.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/20"></div>
    <div class="absolute inset-0 flex items-center">
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-[620px] flex flex-col gap-6">
          <h1 class="text-5xl md:text-7xl font-black text-white tracking-tight leading-[1.1] max-w-[580px]">
            Resultados por sistemas<br />
            <span class="text-white/70 text-4xl md:text-6xl font-bold">No por suerte</span>
          </h1>
          <p class="text-white/85 text-lg md:text-xl leading-relaxed">
            Ingresos predecibles.<br />Construidos sobre sistemas.
          </p>
          <div class="border-l-2 border-white/50 pl-5 text-sm md:text-base text-white/70 leading-snug">
            <p>Ni viralidad. Ni suerte.</p>
            <p>Solo sistemas estructurados.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. FEATURED RESULT -->
  <section class="pt-32 pb-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-5 flex flex-col gap-7">
          <div class="flex items-baseline gap-3 flex-nowrap whitespace-nowrap">
            <span class="text-6xl md:text-8xl font-black text-on-surface tracking-tight leading-none">$24,586</span>
            <span class="text-2xl md:text-3xl font-bold text-on-surface-variant">/mes</span>
          </div>
          <p class="text-xl md:text-2xl text-on-surface font-semibold leading-tight">Construido con sistemas estructurados de monetizaci&oacute;n.</p>
          <p class="text-on-surface-variant text-base leading-relaxed max-w-lg">
            Esta cuenta ya publicaba de forma constante pero no converti&iacute;a. Implementamos chatting estructurado, upsells y sistemas de retenci&oacute;n &mdash; y los ingresos se compusieron desde ah&iacute;.
          </p>
        </div>
        <div class="lg:col-span-7 rounded-2xl overflow-hidden border border-outline-variant/20 shadow-xl aspect-[5/3] bg-white">
          <img src="/assets/results/main-feature-block.jpeg" alt="$24,586 en un solo mes" class="w-full h-full object-cover object-top block" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 3. RESULTS GRID -->
  <section class="pb-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { value: '$19,025', unit: '/mes', text: 'Impulsado por sistemas de chatting optimizados y mejor monetizaci\u00f3n.', img: '/assets/results/results-grid1.jpeg' },
          { value: '$13,098', unit: '/mes', text: 'Crecimiento alineando la estrategia de contenido con los sistemas de conversi\u00f3n.', img: '/assets/results/results-grid2.jpeg' },
          { value: '+558%', unit: 'crecimiento', text: 'De ingresos inconsistentes a ingresos estructurados y predecibles.', img: '/assets/results/results-grid3-v2.jpeg' },
        ].map(card => (
          <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 flex flex-col gap-6">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-5xl md:text-6xl font-black text-on-surface tracking-tight leading-none">{card.value}</span>
              <span class="text-on-surface-variant text-base">{card.unit}</span>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">{card.text}</p>
            <div class="rounded-lg overflow-hidden border border-outline-variant/20 mt-auto aspect-[5/3] bg-white">
              <img src={card.img} alt={card.value} class="w-full h-full object-cover object-top block" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. KEY INSIGHT (BLACK) -->
  <section class="py-40 md:py-52 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-7xl font-black tracking-tight leading-[1.05]">
        La mayor&iacute;a de creadoras no tienen un problema de tr&aacute;fico. <span class="text-white/60">Tienen un problema de monetizaci&oacute;n.</span>
      </h2>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        El tr&aacute;fico sin sistemas no convierte. Nos centramos en lo que de verdad genera dinero.
      </p>
    </div>
  </section>

  <!-- 5. DAILY PERFORMANCE -->
  <section class="py-32 bg-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col gap-14 items-center text-center">
        <div>
          <h2 class="text-5xl md:text-7xl font-black text-on-surface tracking-tight leading-[0.95]">D&iacute;as consistentes de alto rendimiento</h2>
          <p class="mt-5 text-on-surface-variant text-xl md:text-2xl font-semibold">Picos de ingresos impulsados por sistemas estructurados &mdash; no por azar.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block1.jpeg" alt="Ingresos de un solo d&iacute;a superiores a $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block2.jpeg" alt="Ingresos de un solo d&iacute;a superiores a $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FINAL CTA (BLACK) -->
  <section class="py-32 md:py-40 bg-black text-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05]">
        Si tu p&aacute;gina no rinde as&iacute;, hay una raz&oacute;n.
      </h2>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed">
        Te mostramos exactamente qu&eacute; est&aacute; faltando.
      </p>
      <div>
        <a href="/es/#apply" class="inline-block bg-accent text-black font-bold px-10 py-5 rounded-[7px] text-sm tracking-wide hover:brightness-95 hover:scale-[1.02] transition-all">
          Aplicar Ahora
        </a>
      </div>
    </div>
  </section>

</Layout>
