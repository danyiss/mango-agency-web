---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Resultados | MANGO Agency" activeNav="results" lang="es">

  <!-- ─── 1. HERO ─── -->
  <section class="pt-40 pb-24 px-8 max-w-7xl mx-auto text-center">
    <span class="inline-block px-3 py-1 bg-surface-container-high text-secondary text-[10px] font-bold tracking-[0.2em] uppercase rounded-full mb-8">
      Métricas de Rendimiento
    </span>

    <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-[1.05] mb-6 max-w-4xl mx-auto">
      Rendimiento real.<br />
      <span class="text-outline">No teoría.</span>
    </h1>

    <p class="text-lg md:text-xl text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      Combinamos tráfico, chatting y sistemas para generar ingresos consistentes — no picos aleatorios.
    </p>

    <a
      href="#apply"
      class="inline-block bg-gradient-to-br from-primary to-primary-container text-on-primary px-8 py-4 rounded-xl font-bold text-sm tracking-wide hover:opacity-90 transition-all"
    >
      Quiero aplicar
    </a>
  </section>

  <!-- ─── 2. TRAFFIC ─── -->
  <section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">

      <!-- Left text -->
      <div class="lg:col-span-5 space-y-6">
        <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-outline">Fase 01: Atención</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter leading-tight">
          El tráfico no es el problema
        </h2>
        <p class="text-secondary text-base md:text-lg leading-relaxed">
          La mayoría de las creadoras pueden conseguir vistas. Muy pocas saben cómo convertirlas en ingresos. Nos especializamos en el puente entre la atención y el capital.
        </p>

        <!-- Feature pill -->
        <div class="inline-flex items-center gap-2 bg-surface-container-high border border-outline-variant rounded-full px-4 py-2">
          <span class="material-symbols-outlined text-[20px] text-on-surface" style="font-variation-settings:'FILL' 1,'wght' 600,'GRAD' 0,'opsz' 20">trending_up</span>
          <span class="text-sm font-semibold text-on-surface">4M+ vistas en un solo reel</span>
        </div>

        <!-- Blockquote -->
        <blockquote class="border-l-2 border-primary pl-4 italic text-on-surface-variant text-sm leading-relaxed">
          "Tráfico sin monetización = potencial desperdiciado"
        </blockquote>
      </div>

      <!-- Right image -->
      <div class="lg:col-span-7 relative">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden bg-surface-container-highest">
          <img
            src="/assets/df7cff07c6a515fd3f1de6a3e3095c77.png"
            alt="Analíticas de tráfico"
            class="w-full h-full object-cover"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent rounded-3xl flex flex-col justify-end p-8">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-white/60 mb-2">
              <span class="inline-block px-2 py-0.5 border border-white/30 rounded-full mr-2">MÉTRICAS EN VIVO</span>
            </span>
            <p class="text-white text-xs font-semibold uppercase tracking-widest mb-1 opacity-60">Alcance Total</p>
            <p class="text-white text-4xl font-black tracking-tighter">4,289,102</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── 3. MONETIZATION ─── -->
  <section class="py-32 px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">

      <!-- Left: earnings card -->
      <div class="lg:col-span-7">
        <div class="bg-on-surface rounded-3xl p-8 md:p-10 text-on-primary space-y-8">

          <!-- Header -->
          <div class="flex items-start justify-between">
            <div>
              <p class="text-xs text-on-primary/50 uppercase tracking-widest mb-1">Informe de Ingresos Mensuales</p>
              <p class="text-5xl font-black tracking-tighter">$24,182<span class="text-2xl font-bold text-on-primary/70">.44</span></p>
            </div>
            <span class="px-3 py-1 bg-white/10 text-on-primary/70 text-[10px] font-bold tracking-[0.2em] uppercase rounded-full">Verificado</span>
          </div>

          <!-- Progress bars -->
          <div class="space-y-4">
            <div>
              <div class="flex justify-between text-xs text-on-primary/60 mb-1.5">
                <span class="font-semibold">Mensajes Directos (PPV)</span>
                <span>74%</span>
              </div>
              <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-on-primary rounded-full" style="width:74%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-xs text-on-primary/60 mb-1.5">
                <span class="font-semibold">Suscripciones</span>
                <span>18%</span>
              </div>
              <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-on-primary/70 rounded-full" style="width:18%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-xs text-on-primary/60 mb-1.5">
                <span class="font-semibold">Tips y Personalizados</span>
                <span>8%</span>
              </div>
              <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-on-primary/40 rounded-full" style="width:8%"></div>
              </div>
            </div>
          </div>

          <!-- Bottom stats -->
          <div class="grid grid-cols-2 gap-4 pt-4 border-t border-white/10">
            <div>
              <p class="text-xs text-on-primary/40 uppercase tracking-widest mb-0.5">Crecimiento de Ingresos</p>
              <p class="text-2xl font-black text-green-400">+312%</p>
            </div>
            <div>
              <p class="text-xs text-on-primary/40 uppercase tracking-widest mb-0.5">Valor Medio de Pedido</p>
              <p class="text-2xl font-black">$184.20</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right text -->
      <div class="lg:col-span-5 space-y-6">
        <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-outline">Fase 02: Extracción</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter leading-tight">
          Aquí es donde la mayoría de las creadoras falla
        </h2>
        <p class="text-secondary text-base md:text-lg leading-relaxed">
          Los ingresos no vienen de los suscriptores. Vienen de qué tan bien los monetizas.
        </p>

        <!-- Technical insight box -->
        <div class="flex items-start gap-3 bg-surface-container-high rounded-2xl p-5 border border-outline-variant">
          <span class="material-symbols-outlined text-[22px] text-outline mt-0.5 shrink-0">info</span>
          <p class="text-sm text-on-surface-variant leading-relaxed">
            La mayoría de las creadoras gana menos del 12% de su potencial de ingresos. Nuestros sistemas de chatting están diseñados para cerrar esa brecha de forma sistemática — todos los días.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── 4. CONSISTENCY ─── -->
  <section class="bg-primary text-on-primary py-24 px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left -->
      <div class="space-y-8">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter leading-tight">
          No un golpe de suerte.<br />Un sistema.
        </h2>
        <p class="text-on-primary/70 text-base md:text-lg leading-relaxed">
          Todas las creadoras top de nuestro roster tienen algo en común: estructura diaria. Instalamos esa estructura desde el primer día — y la optimizamos semanalmente con datos reales.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-6">
          <div class="bg-white/10 rounded-2xl p-5">
            <p class="text-xs text-on-primary/50 uppercase tracking-widest mb-1">Tasa de Consistencia Diaria</p>
            <p class="text-3xl font-black">98.4%</p>
          </div>
          <div class="bg-white/10 rounded-2xl p-5">
            <p class="text-xs text-on-primary/50 uppercase tracking-widest mb-1">Disponibilidad del Sistema</p>
            <p class="text-3xl font-black">98.4%</p>
          </div>
        </div>

        <blockquote class="border-l-2 border-on-primary/30 pl-4 italic text-on-primary/60 text-sm leading-relaxed">
          "Una creadora que gana de forma consistente $15K/mes supera a quien alcanza $40K un mes y desaparece."
        </blockquote>
      </div>

      <!-- Right: revenue graph card -->
      <div class="bg-zinc-900 rounded-3xl overflow-hidden aspect-[4/3]">
        <img
          src="/assets/ac0b9a4b877fc377d9a21f3b8a9a979a.png"
          alt="Gráfico de ingresos"
          class="w-full h-full object-cover"
        />
      </div>

    </div>
  </section>

  <!-- ─── 5. REVENUE BREAKDOWN ─── -->
  <section class="bg-surface py-32 px-8">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-16 space-y-4">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter">
          De dónde viene realmente el dinero
        </h2>
        <p class="text-secondary text-base md:text-lg max-w-xl mx-auto leading-relaxed">
          Las suscripciones son solo el comienzo. El dinero real vive en las capas de abajo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Card 1: Messages -->
        <div class="p-12 rounded-3xl border border-outline-variant hover:border-primary hover:shadow-lg transition-all duration-300 bg-surface-container-lowest group">
          <span class="material-symbols-outlined text-[40px] text-primary mb-6 block" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 40">chat_bubble</span>
          <h3 class="text-xl font-black tracking-tight mb-3">Mensajes (PPV)</h3>
          <p class="text-secondary text-sm leading-relaxed">Contenido de pago entregado a través de conversaciones directas. El canal de conversión más alto cuando se ejecuta con nuestros marcos de ventas guionizados.</p>
          <p class="text-3xl font-black mt-6">74%<span class="text-sm font-normal text-outline ml-1">de los ingresos</span></p>
        </div>

        <!-- Card 2: Tips -->
        <div class="p-12 rounded-3xl border border-outline-variant hover:border-primary hover:shadow-lg transition-all duration-300 bg-surface-container-lowest group">
          <span class="material-symbols-outlined text-[40px] text-primary mb-6 block" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 40">volunteer_activism</span>
          <h3 class="text-xl font-black tracking-tight mb-3">Tips</h3>
          <p class="text-secondary text-sm leading-relaxed">Espontáneos pero diseñados. Nuestros chatters están entrenados para crear momentos que hacen que el dar tips se sienta natural — y frecuente.</p>
          <p class="text-3xl font-black mt-6">18%<span class="text-sm font-normal text-outline ml-1">de los ingresos</span></p>
        </div>

        <!-- Card 3: Custom -->
        <div class="p-12 rounded-3xl border border-outline-variant hover:border-primary hover:shadow-lg transition-all duration-300 bg-surface-container-lowest group">
          <span class="material-symbols-outlined text-[40px] text-primary mb-6 block" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 40">workspace_premium</span>
          <h3 class="text-xl font-black tracking-tight mb-3">Contenido Personalizado</h3>
          <p class="text-secondary text-sm leading-relaxed">Pedidos de alto valor negociados directamente. Identificamos y calificamos a los mayores gastadores de cada fanbase y los subimos por la escalera de valor.</p>
          <p class="text-3xl font-black mt-6">8%<span class="text-sm font-normal text-outline ml-1">de los ingresos</span></p>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── 6. WHY THIS WORKS ─── -->
  <section class="py-24 px-8 border-t border-outline-variant/20">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left -->
      <div class="space-y-6">
        <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-outline">La infraestructura</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter leading-tight">
          Los resultados no vienen<br />solo del contenido
        </h2>
        <p class="text-secondary text-base md:text-lg leading-relaxed">
          El contenido atrae la atención. Los sistemas la convierten. Hemos construido la capa operacional que la mayoría de las agencias omite por completo.
        </p>
        <p class="text-on-surface font-bold text-lg">
          Esto es lo que convierte el tráfico en ingresos.
        </p>
      </div>

      <!-- Right: hover list -->
      <div class="space-y-2">
        {[
          { icon: "forum", label: "Sistemas de chatting estructurados" },
          { icon: "groups", label: "Equipo dedicado" },
          { icon: "trending_up", label: "Marcos de ventas" },
          { icon: "autorenew", label: "Optimización semanal" },
          { icon: "analytics", label: "Seguimiento de datos" },
        ].map((item) => (
          <div class="group flex items-center justify-between px-6 py-5 rounded-2xl border border-outline-variant hover:border-primary hover:bg-surface-container-high transition-all duration-200 cursor-default">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-[22px] text-outline group-hover:text-primary transition-colors">{item.icon}</span>
              <span class="text-base font-semibold text-on-surface">{item.label}</span>
            </div>
            <span class="material-symbols-outlined text-[20px] text-outline-variant opacity-0 group-hover:opacity-100 group-hover:text-primary transition-all duration-200">chevron_right</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ─── 7. FINAL CTA ─── -->
  <section id="apply" class="py-32 px-8">
    <div class="max-w-5xl mx-auto">
      <div class="bg-primary rounded-[3rem] p-16 md:p-24 text-center">
        <span class="inline-block px-3 py-1 bg-white/10 text-on-primary/60 text-[10px] font-bold tracking-[0.2em] uppercase rounded-full mb-8">
          Plazas Limitadas
        </span>

        <h2 class="text-4xl md:text-6xl font-black tracking-tighter leading-tight text-on-primary mb-6 max-w-2xl mx-auto">
          Si ya tienes tráfico, estás sentada sobre dinero
        </h2>

        <p class="text-on-primary/60 text-base md:text-lg max-w-xl mx-auto mb-10 leading-relaxed">
          No trabajamos con cualquiera. Trabajamos con creadoras que están listas para construir infraestructura — no solo publicar contenido.
        </p>

        <a
          href="https://forms.gle/apply"
          class="inline-block bg-surface-container-lowest text-primary px-10 py-4 rounded-full font-black text-sm tracking-wide hover:bg-white transition-all"
        >
          Quiero aplicar
        </a>

        <p class="text-on-primary/30 text-xs font-bold tracking-[0.2em] uppercase mt-8">
          Solo Creadoras de Élite &nbsp;•&nbsp; Precisión Técnica
        </p>
      </div>
    </div>
  </section>

</Layout>
