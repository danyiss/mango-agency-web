---
import Layout from '../layouts/Layout.astro';
---

<Layout title="For Agencies | MANGO Agency" activeNav="for-agencies">

  <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
  <section class="bg-surface py-24 md:py-40 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-12 gap-8 items-center">

      <!-- Left: Text -->
      <div class="col-span-12 md:col-span-7 flex flex-col gap-6">
        <span class="inline-block px-3 py-1 bg-surface-container-high text-[10px] uppercase tracking-[0.2em] font-bold text-on-surface-variant rounded-sm w-fit">
          Partnership Program
        </span>

        <h1 class="text-5xl md:text-7xl font-black tracking-[-0.03em] text-on-surface leading-[1.02]">
          Scale your agency without scaling your team.
        </h1>

        <p class="text-lg text-secondary max-w-xl leading-relaxed">
          We provide trained chatting teams, systems and performance tracking to handle your volume while you focus on high-level strategy.
        </p>

        <div class="flex flex-wrap gap-4 pt-2">
          <a href="#apply" class="bg-primary text-on-primary px-7 py-3 text-sm font-black uppercase tracking-widest rounded-lg hover:bg-primary-container transition-all">
            Book a call
          </a>
          <a href="#case-studies" class="bg-surface-container-high text-on-surface px-7 py-3 text-sm font-black uppercase tracking-widest rounded-lg hover:bg-surface-container-highest transition-all">
            View Case Studies
          </a>
        </div>
      </div>

      <!-- Right: Image + Floating Stat -->
      <div class="col-span-12 md:col-span-5 relative">
        <div class="aspect-[4/5] rounded-xl overflow-hidden">
          <img
            src="/assets/e2df2479845ad9a0decbf32b7aa3da15.png"
            alt="Agency Partner"
            class="w-full h-full object-cover grayscale"
          />
        </div>

        <!-- Floating stat card -->
        <div class="absolute bottom-6 left-6 bg-white border border-outline-variant/30 rounded-xl px-5 py-4 shadow-lg">
          <p class="text-4xl font-black tracking-[-0.04em] text-on-surface">3.4x</p>
          <p class="text-xs text-secondary font-medium mt-1 max-w-[140px] leading-snug">Average Revenue Growth for Partner Agencies</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── PROBLEM: THE BOTTLENECK ──────────────────────────────────────── -->
  <section class="bg-surface-container py-32 px-6">
    <div class="max-w-7xl mx-auto">

      <div class="max-w-2xl mb-16">
        <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-outline mb-4">The Problem</p>
        <h2 class="text-4xl md:text-5xl font-black tracking-[-0.03em] text-on-surface mb-5">
          The Bottleneck
        </h2>
        <p class="text-lg text-secondary leading-relaxed">
          Internal scaling usually brings operational chaos. We eliminate the three biggest hurdles.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Card 1 -->
        <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:border-outline-variant/50 transition-all cursor-default">
          <div class="w-12 h-12 bg-white rounded-lg shadow-sm flex items-center justify-center mb-6 group-hover:bg-primary transition-all">
            <span class="material-symbols-outlined text-on-surface group-hover:text-on-primary transition-colors text-[22px]">person_search</span>
          </div>
          <h3 class="text-lg font-black tracking-[-0.02em] text-on-surface mb-3">Hiring reliable chatters</h3>
          <p class="text-sm text-secondary leading-relaxed">Stop wasting hours vetting candidates who don't deliver. We handle the entire recruitment and training lifecycle.</p>
        </div>

        <!-- Card 2 -->
        <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:border-outline-variant/50 transition-all cursor-default">
          <div class="w-12 h-12 bg-white rounded-lg shadow-sm flex items-center justify-center mb-6 group-hover:bg-primary transition-all">
            <span class="material-symbols-outlined text-on-surface group-hover:text-on-primary transition-colors text-[22px]">trending_down</span>
          </div>
          <h3 class="text-lg font-black tracking-[-0.02em] text-on-surface mb-3">Inconsistent performance</h3>
          <p class="text-sm text-secondary leading-relaxed">Variable revenue caused by human error. We stabilize your earnings through rigorous SOPs and constant monitoring.</p>
        </div>

        <!-- Card 3 -->
        <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:border-outline-variant/50 transition-all cursor-default">
          <div class="w-12 h-12 bg-white rounded-lg shadow-sm flex items-center justify-center mb-6 group-hover:bg-primary transition-all">
            <span class="material-symbols-outlined text-on-surface group-hover:text-on-primary transition-colors text-[22px]">visibility_off</span>
          </div>
          <h3 class="text-lg font-black tracking-[-0.02em] text-on-surface mb-3">Lack of QA</h3>
          <p class="text-sm text-secondary leading-relaxed">You shouldn't be the one checking every message. Our internal Quality Assurance team audits every interaction.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── SOLUTION: BENTO GRID ─────────────────────────────────────────── -->
  <section class="bg-surface py-32 px-6">
    <div class="max-w-7xl mx-auto">

      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-outline mb-4">The Solution</p>
        <h2 class="text-4xl md:text-5xl font-black tracking-[-0.03em] text-on-surface mb-5">
          A Professional Backbone
        </h2>
        <p class="text-lg text-secondary leading-relaxed">
          Engineered for agencies that demand technical precision and elite execution.
        </p>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-6 grid-rows-2 gap-6">

        <!-- Main card: col-span-3 row-span-2 -->
        <div class="col-span-6 md:col-span-3 md:row-span-2 bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-8 flex flex-col justify-between min-h-[380px]">
          <div>
            <span class="inline-block px-2 py-0.5 bg-surface-container-high text-[9px] uppercase tracking-[0.18em] font-bold text-outline rounded-sm mb-6">Core Offering</span>
            <h3 class="text-3xl font-black tracking-[-0.03em] text-on-surface mb-4 leading-tight">
              Trained chatting teams
            </h3>
            <p class="text-sm text-secondary leading-relaxed max-w-sm">
              Hand-picked, protocol-trained chatters embedded into your operation. Each team is briefed on your brand voice, escalation rules and conversion goals before day one.
            </p>
          </div>

          <div>
            <!-- Team avatars -->
            <div class="flex items-center mb-4">
              <div class="flex -space-x-3">
                <img src="/assets/9cc4b0c345917522090a21963cb97d19.png" alt="Team member" class="w-10 h-10 rounded-full object-cover border-2 border-white grayscale" />
                <img src="/assets/537c22277386c665d1e34e78fa99f8f5.png" alt="Team member" class="w-10 h-10 rounded-full object-cover border-2 border-white grayscale" />
                <img src="/assets/dc256e12fcd994ae6442ebda0345f7d9.png" alt="Team member" class="w-10 h-10 rounded-full object-cover border-2 border-white grayscale" />
                <div class="w-10 h-10 rounded-full bg-surface-container-high border-2 border-white flex items-center justify-center">
                  <span class="text-[10px] font-bold text-secondary">+12</span>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-on-surface animate-pulse"></div>
              <span class="text-xs font-bold text-on-surface uppercase tracking-widest">24/7 Global Coverage</span>
            </div>
          </div>
        </div>

        <!-- QA card: col-span-3, bg-primary -->
        <div class="col-span-6 md:col-span-3 bg-primary rounded-xl p-8 flex flex-col justify-between min-h-[175px]">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-[9px] uppercase tracking-[0.18em] font-bold text-on-primary/50 mb-3">Quality Assurance</p>
              <h3 class="text-2xl font-black tracking-[-0.03em] text-on-primary mb-3 leading-tight">QA Monitoring</h3>
              <p class="text-sm text-on-primary/70 leading-relaxed max-w-xs">
                Every conversation reviewed. We flag deviations, coach in real time and maintain a zero-tolerance policy on off-script interactions.
              </p>
            </div>
            <div class="w-12 h-12 bg-white/10 rounded-lg flex items-center justify-center flex-shrink-0 ml-4">
              <span class="material-symbols-outlined text-on-primary text-[22px]">verified_user</span>
            </div>
          </div>
        </div>

        <!-- Proven systems card -->
        <div class="col-span-6 md:col-span-3 bg-surface-container rounded-xl p-8 min-h-[175px] flex flex-col justify-between border border-outline-variant/20">
          <span class="material-symbols-outlined text-on-surface-variant text-[28px]">schema</span>
          <div>
            <h3 class="text-lg font-black tracking-[-0.02em] text-on-surface mb-2">Proven systems</h3>
            <p class="text-sm text-secondary leading-relaxed">Battle-tested SOPs refined across dozens of agencies and thousands of daily conversations.</p>
          </div>
        </div>

        <!-- Scalable structure card (hidden on mobile to keep symmetry, shown md+) -->
        <!-- Actually keep it always visible but adjust colspan -->
        <!-- We only have 4 bento items total fitting into 2 rows × 6 cols -->
        <!-- Row 1: main(3) + QA(3) | Row 2: main(3) + proven(1.5) + scalable(1.5) -->
        <!-- Tailwind doesn't allow fractional cols; use col-span-2 within the right 3 cols -->

      </div>

      <!-- Second bento row for the two small cards (md: they sit inside the right col beside the main card) -->
      <!-- On desktop these need to be inside a 3-col sub-grid on the right, row 2 -->
      <!-- Simplest: use a nested grid approach -->
      <div class="grid grid-cols-2 gap-6 mt-6 md:hidden">
        <div class="bg-surface-container rounded-xl p-6 border border-outline-variant/20 flex flex-col gap-4">
          <span class="material-symbols-outlined text-on-surface-variant text-[28px]">hub</span>
          <div>
            <h3 class="text-base font-black tracking-[-0.02em] text-on-surface mb-1">Scalable structure</h3>
            <p class="text-xs text-secondary leading-relaxed">From 5 to 500 creators — the infrastructure adapts without bottlenecks or ramp-up delays.</p>
          </div>
        </div>
        <div class="bg-surface-container rounded-xl p-6 border border-outline-variant/20 flex flex-col gap-4">
          <span class="material-symbols-outlined text-on-surface-variant text-[28px]">insights</span>
          <div>
            <h3 class="text-base font-black tracking-[-0.02em] text-on-surface mb-1">Performance data</h3>
            <p class="text-xs text-secondary leading-relaxed">Weekly reports with revenue attribution, conversion rates and chatter-level analytics.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── INTEGRATION ───────────────────────────────────────────────────── -->
  <section class="bg-surface-container-low py-32 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-12 gap-12 items-center">

      <!-- Left: Technical visualization card -->
      <div class="col-span-12 md:col-span-6 order-2 md:order-1">
        <div class="bg-white rounded-xl border border-outline-variant/20 shadow-sm overflow-hidden">
          <!-- Card header -->
          <div class="px-6 py-4 border-b border-outline-variant/20 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-surface-container-highest"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-surface-container-highest"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-surface-container-highest"></div>
            </div>
            <span class="text-[9px] uppercase tracking-[0.18em] font-bold text-outline">Integration Status</span>
            <div class="w-2 h-2 rounded-full bg-on-surface animate-pulse"></div>
          </div>

          <!-- Steps -->
          <div class="px-6 py-6 flex flex-col gap-4">

            <!-- Step 1: ACTIVE -->
            <div class="flex items-center justify-between p-4 bg-on-surface rounded-lg">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-on-primary/10 rounded-md flex items-center justify-center">
                  <span class="material-symbols-outlined text-on-primary text-[16px]">electrical_services</span>
                </div>
                <div>
                  <p class="text-xs font-black text-on-primary tracking-tight">API Integration</p>
                  <p class="text-[10px] text-on-primary/50 font-medium mt-0.5">Connected to platform</p>
                </div>
              </div>
              <span class="text-[9px] uppercase tracking-[0.15em] font-black text-on-primary/80 bg-on-primary/10 px-2.5 py-1 rounded-full">ACTIVE</span>
            </div>

            <!-- Step 2: QUEUED -->
            <div class="flex items-center justify-between p-4 bg-surface-container rounded-lg border border-outline-variant/20">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-surface-container-high rounded-md flex items-center justify-center">
                  <span class="material-symbols-outlined text-on-surface-variant text-[16px]">group_add</span>
                </div>
                <div>
                  <p class="text-xs font-black text-on-surface tracking-tight">Assign Chatters</p>
                  <p class="text-[10px] text-secondary font-medium mt-0.5">Talent matching in progress</p>
                </div>
              </div>
              <span class="text-[9px] uppercase tracking-[0.15em] font-black text-secondary bg-surface-container-highest px-2.5 py-1 rounded-full">QUEUED</span>
            </div>

            <!-- Step 3: STANDBY -->
            <div class="flex items-center justify-between p-4 bg-surface-container rounded-lg border border-outline-variant/20 opacity-60">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-surface-container-high rounded-md flex items-center justify-center">
                  <span class="material-symbols-outlined text-on-surface-variant text-[16px]">auto_graph</span>
                </div>
                <div>
                  <p class="text-xs font-black text-on-surface tracking-tight">Optimize Yield</p>
                  <p class="text-[10px] text-secondary font-medium mt-0.5">Awaiting live data</p>
                </div>
              </div>
              <span class="text-[9px] uppercase tracking-[0.15em] font-black text-outline bg-surface-container-high px-2.5 py-1 rounded-full">STANDBY</span>
            </div>
          </div>

          <!-- Footer bar -->
          <div class="px-6 py-3 bg-on-surface flex items-center justify-between">
            <span class="text-[9px] uppercase tracking-[0.15em] font-bold text-on-primary/60">MANGO INTEGRATION ENGINE</span>
            <span class="text-[9px] font-bold text-on-primary/40">v2.4.1</span>
          </div>
        </div>
      </div>

      <!-- Right: Text + steps -->
      <div class="col-span-12 md:col-span-6 order-1 md:order-2 flex flex-col gap-10">
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-outline mb-4">How It Works</p>
          <h2 class="text-4xl md:text-5xl font-black tracking-[-0.03em] text-on-surface leading-tight">
            Seamless Integration
          </h2>
        </div>

        <div class="flex flex-col gap-8">

          <!-- Step 01 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 bg-surface-container-high rounded-lg flex items-center justify-center">
              <span class="text-[11px] font-black text-outline">01</span>
            </div>
            <div>
              <h3 class="text-base font-black tracking-[-0.02em] text-on-surface mb-1.5">We integrate with your operation</h3>
              <p class="text-sm text-secondary leading-relaxed">Zero disruption. We slide into your existing workflow, platform stack and communication channels without breaking what's working.</p>
            </div>
          </div>

          <!-- Step 02 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 bg-surface-container-high rounded-lg flex items-center justify-center">
              <span class="text-[11px] font-black text-outline">02</span>
            </div>
            <div>
              <h3 class="text-base font-black tracking-[-0.02em] text-on-surface mb-1.5">Assign chatters</h3>
              <p class="text-sm text-secondary leading-relaxed">Dedicated account managers select the best-fit talent for your roster — matched by language, timezone and creator profile type.</p>
            </div>
          </div>

          <!-- Step 03 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 bg-surface-container-high rounded-lg flex items-center justify-center">
              <span class="text-[11px] font-black text-outline">03</span>
            </div>
            <div>
              <h3 class="text-base font-black tracking-[-0.02em] text-on-surface mb-1.5">Optimize performance</h3>
              <p class="text-sm text-secondary leading-relaxed">We constantly AB test scripts and triggers to maximize LTV. Weekly data loops keep every account trending upward.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ─── FINAL CTA ─────────────────────────────────────────────────────── -->
  <section id="apply" class="bg-primary py-24 px-6">
    <div class="max-w-7xl mx-auto text-center flex flex-col items-center gap-8">
      <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-on-primary/50">Partnership Program</p>
      <h2 class="text-4xl md:text-6xl font-black tracking-[-0.03em] text-on-primary max-w-2xl leading-tight">
        Ready to scale professionally?
      </h2>
      <p class="text-lg text-on-primary/60 max-w-lg leading-relaxed">
        Join agencies already running at scale. One call is all it takes to start.
      </p>
      <a
        href="https://calendly.com/mangova"
        target="_blank"
        rel="noopener"
        class="bg-white text-primary px-10 py-4 rounded-lg text-sm font-black uppercase tracking-widest hover:bg-surface-container-low transition-all"
      >
        Book a call
      </a>
    </div>
  </section>

</Layout>
