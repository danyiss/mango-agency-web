---
import Layout from '../layouts/Layout.astro';
import AgencyApplyForm from '../components/AgencyApplyForm.astro';
---

<Layout title="For Agencies | MANGO Agency" activeNav="for-agencies" lang="en">

  <!-- 1. HERO -->
  <section class="pt-32 pb-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-4xl">
        <span class="text-xs font-bold tracking-widest uppercase text-outline mb-6 block">For agencies</span>
        <h1 class="text-5xl md:text-7xl font-black text-on-surface tracking-tight leading-[1.05] mb-6">
          Increase your model&rsquo;s revenue &mdash; without changing your system
        </h1>
        <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-2xl mb-8">
          We handle chatting, monetization, and sales systems so you can focus on traffic, content, and growth.
        </p>
        <div class="border-l-2 border-primary pl-5 max-w-xl mb-10">
          <p class="text-base md:text-lg text-on-surface font-semibold leading-snug">
            You keep the model, the brand, and the relationship.
          </p>
          <p class="text-base md:text-lg text-on-surface-variant leading-snug">
            We increase the revenue.
          </p>
        </div>
        <a href="#agency-apply" class="inline-block bg-primary text-on-primary font-bold px-8 py-4 rounded-xl text-sm tracking-wide hover:bg-primary-container transition-all">
          Apply now
        </a>
      </div>
    </div>
  </section>

  <!-- 2. TARGET CLARITY -->
  <section class="py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-14">
        <span class="text-xs font-bold tracking-widest uppercase text-outline mb-4 block">Who this is for</span>
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">This is for</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          'Agencies managing models but lacking strong monetization.',
          'Agencies that want to increase revenue without hiring and training chatters.',
          'High-performing creators who want to delegate chatting without losing control.',
        ].map(t => (
          <div class="bg-surface-container-lowest p-10 rounded-2xl border border-outline-variant/20 flex flex-col gap-5">
            <span class="material-symbols-outlined text-primary" style="font-size:28px;font-variation-settings:'FILL' 1;">check_circle</span>
            <p class="text-on-surface text-lg font-semibold leading-snug">{t}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. CORE VALUE -->
  <section class="py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-20">
        <span class="text-xs font-bold tracking-widest uppercase text-outline mb-4 block">Core value</span>
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">
          We don&rsquo;t just handle chatting &mdash; we build revenue systems.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { num: '01', title: 'Dedicated chatting team', text: 'A trained team assigned to your model, working in their tone and style.' },
          { num: '02', title: 'Sales systems', text: 'Structured upsells, retention, and messaging systems designed to maximize revenue.' },
          { num: '03', title: 'Performance optimization', text: 'We track results, analyze performance, and continuously improve conversion.' },
        ].map(p => (
          <div class="bg-surface-container-lowest p-10 md:p-12 rounded-2xl border border-outline-variant/20 flex flex-col gap-8 hover:shadow-lg transition-shadow min-h-[320px]">
            <span class="text-6xl font-black text-outline-variant/40 leading-none">{p.num}</span>
            <div class="flex flex-col gap-4 mt-auto">
              <h3 class="text-2xl md:text-3xl font-black text-on-surface tracking-tight">{p.title}</h3>
              <p class="text-on-surface-variant text-base leading-relaxed">{p.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. DIFFERENTIATION (BLACK) -->
  <section class="py-40 md:py-52 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-7xl font-black tracking-tight leading-[1.05]">
        Most chatting services just reply to messages. <span class="text-white/60">We focus on converting conversations into revenue.</span>
      </h2>
    </div>
  </section>

  <!-- 5. HOW IT WORKS -->
  <section class="py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-20">
        <span class="text-xs font-bold tracking-widest uppercase text-outline mb-4 block">How it works</span>
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">Plug in. Scale revenue.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-outline-variant/30">
        {[
          { num: '01', title: 'Integrate', text: 'We integrate with your existing setup.' },
          { num: '02', title: 'Take over', text: 'We take over chatting and monetization.' },
          { num: '03', title: 'Scale', text: 'We optimize performance and scale revenue.' },
        ].map(step => (
          <div class="flex flex-col gap-5 px-0 md:px-10 py-10 first:pt-0 md:first:pt-10 md:first:pl-0 md:last:pr-0">
            <span class="text-5xl md:text-6xl font-black text-on-surface tracking-tight leading-none">{step.num}</span>
            <h3 class="text-2xl md:text-3xl font-black text-on-surface tracking-tight">{step.title}</h3>
            <p class="text-on-surface-variant text-base leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. BENEFITS -->
  <section class="py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <span class="text-xs font-bold tracking-widest uppercase text-outline mb-4 block">Benefits</span>
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">What you get.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          'Higher revenue per model.',
          'No need to hire or manage chatters.',
          'Scalable systems without operational complexity.',
        ].map(b => (
          <div class="bg-surface-container-lowest p-10 rounded-2xl border border-outline-variant/20 flex items-start gap-4">
            <span class="material-symbols-outlined text-primary flex-shrink-0 mt-0.5" style="font-size:24px;font-variation-settings:'FILL' 1;">trending_up</span>
            <p class="text-on-surface text-lg font-semibold leading-snug">{b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. PRE-FORM CTA (BLACK) -->
  <section class="py-28 md:py-32 bg-black text-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-6">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-[1.1]">
        If your models have traffic but aren&rsquo;t converting &mdash; this is where the money is lost.
      </h2>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed">Let&rsquo;s fix it.</p>
    </div>
  </section>

  <!-- 8. AGENCY APPLICATION FORM -->
  <AgencyApplyForm lang="en" />

</Layout>
