---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MANGO | For Creators, By Creators" activeNav="home">

  <!-- 1. HERO SECTION -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/assets/340bd35d3f89611dfd4fd778ec3d40c6.png');"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/30 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-32 flex flex-col items-start gap-8">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5">
        <span class="material-symbols-outlined text-white" style="font-size:14px;">bolt</span>
        <span class="text-white/80 text-xs font-semibold tracking-widest uppercase">System-Driven Agency</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-white leading-[1.05] tracking-tight max-w-3xl">
        For creators<br />by creators
      </h1>
      <p class="text-white/70 text-lg md:text-xl max-w-xl leading-relaxed">
        A system-driven agency for creators ready to move from management to infrastructure. Built for performance, not just posting.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#apply"
          class="bg-white text-black font-bold px-8 py-4 rounded-xl text-sm tracking-wide hover:bg-white/90 transition-all shadow-lg"
        >
          Apply to work with us
        </a>
        <a
          href="#how-it-works"
          class="border border-white/30 text-white font-semibold px-8 py-4 rounded-xl text-sm tracking-wide hover:bg-white/10 transition-all backdrop-blur-sm"
        >
          See how it works
        </a>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
      <span class="text-xs font-medium tracking-widest uppercase">Scroll</span>
      <span class="material-symbols-outlined animate-bounce">keyboard_arrow_down</span>
    </div>
  </section>

  <!-- 2. PROBLEM SECTION -->
  <section class="py-28 bg-surface px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <span class="text-xs font-bold tracking-widest uppercase text-outline">The Friction</span>
        <h2 class="mt-3 text-4xl md:text-5xl font-black text-on-surface tracking-tight">Why you're stuck</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">trending_down</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Posting but not growing</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">Stagnant reach despite consistent effort. You're shouting into a void without a tactical traffic funnel.</p>
          </div>
        </div>
        <!-- Card 2 -->
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">payments</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Subs aren't spending</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">Low conversion rates and missed tips. Your current chatting setup lacks the sales psychology needed to scale.</p>
          </div>
        </div>
        <!-- Card 3 -->
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">bolt</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Operational burnout</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">Drowning in manual tasks. Without SOPs, you aren't a creator, you're an administrator of your own stress.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SOLUTION SECTION -->
  <section class="py-28 bg-surface-container px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Text -->
      <div class="flex flex-col gap-8">
        <div>
          <span class="text-xs font-bold tracking-widest uppercase text-outline">The Solution</span>
          <h2 class="mt-3 text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">The MANGO Infrastructure</h2>
        </div>
        <p class="text-on-surface-variant text-lg leading-relaxed">
          We don't just 'manage' accounts. We build backend systems that treat your brand like a high-growth tech startup.
        </p>
        <div class="flex flex-col gap-6">
          <!-- Item 1 -->
          <div class="flex gap-4 items-start">
            <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="material-symbols-outlined text-on-primary" style="font-size:14px;font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 24;">check</span>
            </div>
            <div>
              <h4 class="font-bold text-on-surface mb-1">Traffic Layer</h4>
              <p class="text-on-surface-variant text-sm leading-relaxed">Aggressive Instagram + Reddit dominance through proprietary automation and viral loops.</p>
            </div>
          </div>
          <!-- Item 2 -->
          <div class="flex gap-4 items-start">
            <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="material-symbols-outlined text-on-primary" style="font-size:14px;font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 24;">check</span>
            </div>
            <div>
              <h4 class="font-bold text-on-surface mb-1">Monetization</h4>
              <p class="text-on-surface-variant text-sm leading-relaxed">Advanced chatting + sales systems. Data-backed scripts that maximize LTV per subscriber.</p>
            </div>
          </div>
          <!-- Item 3 -->
          <div class="flex gap-4 items-start">
            <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="material-symbols-outlined text-on-primary" style="font-size:14px;font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 24;">check</span>
            </div>
            <div>
              <h4 class="font-bold text-on-surface mb-1">Operations Layer</h4>
              <p class="text-on-surface-variant text-sm leading-relaxed">Systems, SOPs, and tracking. Real-time dashboards showing you exactly where every dollar comes from.</p>
            </div>
          </div>
        </div>
      </div>
      <!-- Right: Image -->
      <div class="relative">
        <img
          src="/assets/03c0cffb3453db98c7fe27e573661a58.png"
          alt="MANGO Infrastructure"
          class="w-full aspect-square object-cover rounded-2xl shadow-2xl"
        />
      </div>
    </div>
  </section>

  <!-- 4. HOW IT WORKS -->
  <section id="how-it-works" class="py-28 bg-white px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight">From Application to Scale</h2>
        <p class="mt-4 text-on-surface-variant text-lg max-w-xl mx-auto">A precise 4-step deployment of our systems.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-outline-variant/20">
        <!-- Step 01 -->
        <div class="flex flex-col gap-4 px-8 py-10 first:pl-0 last:pr-0">
          <span class="text-7xl font-black text-outline-variant/30 leading-none">01</span>
          <h3 class="text-xl font-black text-on-surface">Apply</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Initial audit of your current assets and growth potential.</p>
        </div>
        <!-- Step 02 -->
        <div class="flex flex-col gap-4 px-8 py-10">
          <span class="text-7xl font-black text-outline-variant/30 leading-none">02</span>
          <h3 class="text-xl font-black text-on-surface">Evaluation Call</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Deep dive into your goals and our custom infrastructure plan.</p>
        </div>
        <!-- Step 03 -->
        <div class="flex flex-col gap-4 px-8 py-10">
          <span class="text-7xl font-black text-outline-variant/30 leading-none">03</span>
          <h3 class="text-xl font-black text-on-surface">Strategy Setup</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Deploying the Traffic and Operations layers within 72 hours.</p>
        </div>
        <!-- Step 04 -->
        <div class="flex flex-col gap-4 px-8 py-10">
          <span class="text-7xl font-black text-outline-variant/30 leading-none">04</span>
          <h3 class="text-xl font-black text-on-surface">Launch & Scale</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Aggressive monetization and daily data-driven optimizations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. DIFFERENTIATION -->
  <section class="py-28 bg-surface px-6">
    <div class="max-w-7xl mx-auto">
      <div class="bg-primary rounded-3xl overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
          <!-- Left: Text -->
          <div class="flex flex-col gap-10 p-12 lg:p-16">
            <h2 class="text-4xl md:text-5xl font-black leading-[1.1] tracking-tight">
              <span class="text-white">A Real Business,</span><br />
              <span class="text-white/40">Not a Freelancer.</span>
            </h2>
            <div class="flex flex-col gap-8">
              <!-- Item 1 -->
              <div class="flex gap-5 items-start">
                <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                  <span class="material-symbols-outlined text-white" style="font-size:20px;">groups</span>
                </div>
                <div>
                  <h4 class="font-bold text-white mb-1">Dedicated Teams</h4>
                  <p class="text-white/60 text-sm leading-relaxed">No generalists. Specific experts for chatting, promotion, and data.</p>
                </div>
              </div>
              <!-- Item 2 -->
              <div class="flex gap-5 items-start">
                <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                  <span class="material-symbols-outlined text-white" style="font-size:20px;">visibility</span>
                </div>
                <div>
                  <h4 class="font-bold text-white mb-1">Full Transparency</h4>
                  <p class="text-white/60 text-sm leading-relaxed">24/7 access to your revenue dashboards and chat logs.</p>
                </div>
              </div>
              <!-- Item 3 -->
              <div class="flex gap-5 items-start">
                <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                  <span class="material-symbols-outlined text-white" style="font-size:20px;">security</span>
                </div>
                <div>
                  <h4 class="font-bold text-white mb-1">Secure Infrastructure</h4>
                  <p class="text-white/60 text-sm leading-relaxed">Advanced security protocols to protect your identity and content.</p>
                </div>
              </div>
            </div>
            <div>
              <a
                href="#apply"
                class="inline-flex items-center gap-2 bg-white text-black font-bold px-7 py-3.5 rounded-xl text-sm hover:bg-white/90 transition-all"
              >
                Apply Now
                <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
              </a>
            </div>
          </div>
          <!-- Right: Image -->
          <div class="relative hidden lg:flex items-center justify-center overflow-hidden">
            <img
              src="/assets/5a20460e35b065f9248e5ead5ad27034.png"
              alt="Real business"
              class="w-full h-full object-cover opacity-40 mix-blend-screen"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FAQ SECTION -->
  <section class="py-28 bg-white px-6">
    <div class="max-w-3xl mx-auto">
      <div class="mb-14">
        <span class="text-xs font-bold tracking-widest uppercase text-outline">Expertise</span>
        <h2 class="mt-3 text-4xl md:text-5xl font-black text-on-surface tracking-tight">Frequently Asked Questions</h2>
      </div>
      <div class="flex flex-col gap-3">

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">What makes your agency different from others?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            We operate differently: Dedicated chatting team per model (not shared), Structured sales frameworks, Weekly performance analysis, Full system (chatting + marketing + operations). This is not random management. This is a structured system designed to scale revenue.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">Why should I work with an agency?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            Because most creators are leaving money on the table. 70–80% of revenue comes from chatting, but it requires consistency, strategy, and time. We handle that entire side for you — with a trained team and performance tracking — so you can focus on content and growth.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">How much can I expect to grow?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            It depends on your starting point. However, most creators see: Higher revenue per subscriber, Better conversion from subs to buyers, More consistent daily earnings. Our goal is not just growth — it's building a stable and scalable income system.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">Is it safe to give access to my account?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            Yes. We do NOT require your OnlyFans credentials. You connect your account securely through Infloww, which allows us to manage conversations without direct access to your login details.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">Will you change my personality or how I interact with fans?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            No. We adapt to your personality, not the other way around. Before starting, we collect detailed information about your tone, preferences, and limits.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">How does the process work?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            Apply → Evaluation call → System setup → Launch & optimization. We can be up and running very quickly once the strategy is aligned.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">Do I keep control of my account?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            Yes, always. You keep full ownership and visibility at all times.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">How is your chatting quality maintained?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            We rely on systems: 24/7 monitoring, dedicated QA team, continuous optimization, and performance tracking per chatter.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">Can I stop anytime?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            Yes. We don't lock creators into long-term contracts.
          </div>
        </details>

        <details class="bg-surface-container-low rounded-2xl group">
          <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
            <span class="font-semibold text-on-surface text-base pr-6">How do payments work?</span>
            <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">
            Performance-based model. Details discussed during the evaluation call to ensure it matches your specific situation.
          </div>
        </details>

      </div>
    </div>
  </section>

  <!-- 7. FINAL CTA SECTION -->
  <section id="apply" class="py-28 bg-surface px-6">
    <div class="max-w-7xl mx-auto flex flex-col items-center text-center gap-8">
      <h2 class="text-5xl md:text-6xl font-black text-on-surface tracking-tight">Ready to scale?</h2>
      <p class="text-on-surface-variant text-lg max-w-lg leading-relaxed">
        We only work with a limited number of creators to maintain system integrity and personalized service.
      </p>
      <a
        href="https://instagram.com/mangova.agency"
        target="_blank"
        rel="noopener"
        class="bg-primary text-on-primary font-bold px-10 py-4 rounded-2xl text-sm tracking-wide hover:bg-primary-container transition-all shadow-lg"
      >
        Apply to work with us
      </a>

      <!-- Stats row -->
      <div class="w-full max-w-2xl mt-6 border-t border-outline-variant/20 pt-10 grid grid-cols-3 gap-0 divide-x divide-outline-variant/20">
        <div class="flex flex-col items-center gap-1 px-6">
          <span class="text-4xl font-black text-on-surface">94%</span>
          <span class="text-xs font-semibold text-outline uppercase tracking-widest">Avg. Growth</span>
        </div>
        <div class="flex flex-col items-center gap-1 px-6">
          <span class="text-4xl font-black text-on-surface">$4M+</span>
          <span class="text-xs font-semibold text-outline uppercase tracking-widest">Managed Rev</span>
        </div>
        <div class="flex flex-col items-center gap-1 px-6">
          <span class="text-4xl font-black text-on-surface">15</span>
          <span class="text-xs font-semibold text-outline uppercase tracking-widest">Elite Creators</span>
        </div>
      </div>
    </div>
  </section>

</Layout>
