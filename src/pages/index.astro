---
import Layout from '../layouts/Layout.astro';
import ApplyForm from '../components/ApplyForm.astro';
import { useTranslations } from '../i18n/translations';

const t = useTranslations('en');

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": t('home.faq.q1'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a1') }},
    { "@type": "Question", "name": t('home.faq.q2'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a2') }},
    { "@type": "Question", "name": t('home.faq.q3'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a3') }},
    { "@type": "Question", "name": t('home.faq.q4'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a4') }},
    { "@type": "Question", "name": t('home.faq.q5'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a5') }},
    { "@type": "Question", "name": t('home.faq.q6'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a6') }},
    { "@type": "Question", "name": t('home.faq.q7'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a7') }},
    { "@type": "Question", "name": t('home.faq.q8'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a8') }},
    { "@type": "Question", "name": t('home.faq.q9'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a9') }},
    { "@type": "Question", "name": t('home.faq.q10'), "acceptedAnswer": { "@type": "Answer", "text": t('home.faq.a10') }},
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "OnlyFans Management",
  "provider": { "@type": "Organization", "name": "MANGO Agency" },
  "description": "System-driven talent management for content creators. Chatting operations, marketing strategy, traffic generation, and operational optimization.",
  "serviceType": "Talent Management Agency",
  "areaServed": ["Europe", "Asia"],
};
---

<Layout title="MANGO | For Creators, By Creators" activeNav="home" lang="en" transparentTop={true}>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/assets/hero.webp" type="image/webp" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 1. HERO SECTION -->
  <section class="relative h-screen -mt-16 w-full overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/hero.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/50 to-black/20"></div>
    <div class="absolute inset-0 flex items-center">
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full flex flex-col gap-6 md:gap-8">
      <span class="text-xs md:text-sm font-medium text-white/50 tracking-[0.25em] uppercase">For creators, by creators</span>
      <h1 class="text-5xl md:text-7xl font-black text-white leading-[1.05] tracking-tight max-w-5xl">
        Scale your OnlyFans into<br />predictable 5&ndash;6 figure months
      </h1>
      <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-2xl">
        We build the systems behind top creators &mdash; so you can focus on content while we handle growth and monetization.
      </p>
      <div>
        <a href="#apply" class="bg-white text-black font-bold px-8 py-4 rounded-xl text-sm tracking-wide hover:bg-white/90 transition-all shadow-lg inline-block">
          Apply Now
        </a>
      </div>
    </div>
    </div>
    <div class="absolute bottom-6 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
      <span class="text-xs font-medium tracking-widest uppercase">{t('home.hero.scroll')}</span>
      <span class="material-symbols-outlined animate-bounce">keyboard_arrow_down</span>
    </div>
  </section>

  <!-- 2. STATEMENT SECTION (black) -->
  <section class="py-28 md:py-36 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-[1.15]">
        Most creators make 20% of what they could. <span class="text-white/60">We fix the other 80%.</span>
      </h2>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        The issue usually isn&rsquo;t effort &mdash; it&rsquo;s lack of systems, monetization, and execution.
      </p>
    </div>
  </section>

  <!-- 3a. RESULTS HEADER + MAIN FEATURE (WHITE) -->
  <section id="results" class="pt-32 pb-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-24">
        <h2 class="text-4xl md:text-6xl font-black text-on-surface tracking-tight leading-[1.05]">Revenue is all that matters.</h2>
        <p class="mt-5 text-on-surface-variant text-lg">We focus on what actually moves your income forward.</p>
      </div>

      <!-- Featured hero proof -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-5 flex flex-col gap-7">
          <div class="flex items-baseline gap-3 flex-wrap">
            <span class="text-6xl md:text-8xl font-black text-on-surface tracking-tight leading-none">$24,586</span>
            <span class="text-2xl md:text-3xl font-bold text-on-surface-variant">/month</span>
          </div>
          <p class="text-xl md:text-2xl text-on-surface font-semibold leading-tight">Without relying on subscriptions.</p>
          <p class="text-on-surface-variant text-base leading-relaxed max-w-lg">
            Before working with us, this account was underperforming despite consistent posting. The issue wasn&rsquo;t content &mdash; it was lack of monetization systems.
          </p>
        </div>
        <div class="lg:col-span-7 rounded-2xl overflow-hidden border border-outline-variant/20 shadow-xl aspect-[5/3] bg-white">
          <img src="/assets/results/main-feature-block.jpeg" alt="$24,586 in a single month" class="w-full h-full object-cover object-top block" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 3b. RESULTS GRID (WHITE) -->
  <section class="pb-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { value: '$19,025', unit: '/month', text: 'Built through consistent monetization systems \u2014 not just traffic.', img: '/assets/results/results-grid1.jpeg' },
          { value: '$13,098', unit: '/month', text: 'Scaling with structured content + chatting integration.', img: '/assets/results/results-grid2.jpeg' },
          { value: '+558%', unit: 'growth', text: 'From underperforming to structured revenue in weeks.', img: '/assets/results/results-grid3-v2.jpeg' },
        ].map(card => (
          <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 flex flex-col gap-6">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-5xl md:text-6xl font-black text-on-surface tracking-tight leading-none">{card.value}</span>
              <span class="text-on-surface-variant text-base">{card.unit}</span>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">{card.text}</p>
            <div class="rounded-lg overflow-hidden border border-outline-variant/20 mt-auto aspect-[5/3] bg-white">
              <img src={card.img} alt={card.value} class="w-full h-full object-cover object-top block" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3c. INSIGHT BLOCK (BLACK, FULL-WIDTH, HIGH CONTRAST) -->
  <section class="py-40 md:py-52 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h3 class="text-4xl md:text-7xl font-black tracking-tight leading-[1.05]">Most revenue doesn&rsquo;t come from subscriptions.</h3>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        Up to 70&ndash;85% comes from DMs, upsells, and structured chatting systems.
      </p>
    </div>
  </section>

  <!-- 3d. DAILY PERFORMANCE (WHITE) -->
  <section class="py-32 bg-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col gap-14 items-center text-center">
        <div>
          <h3 class="text-5xl md:text-7xl font-black text-on-surface tracking-tight leading-[0.95]">$2k+ days &mdash; consistently</h3>
          <p class="mt-5 text-on-surface-variant text-xl md:text-2xl font-semibold">Not luck. Systems.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block1.jpeg" alt="Single-day earnings over $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-outline-variant/20 shadow-lg aspect-[5/3] bg-white">
            <img src="/assets/results/daily-performance-block2.jpeg" alt="Single-day earnings over $2k" class="w-full h-full object-cover object-top block" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3e. SYSTEM EXPLANATION (SURFACE) -->
  <section class="py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-20">
        <h3 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">What&rsquo;s behind these results?</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { n: '01', title: 'Dedicated chatting team per model', text: 'Every creator gets a trained, in-house team focused on their account \u2014 not shared across dozens.' },
          { n: '02', title: 'Structured sales systems', text: 'DMs, upsells, and retention flows engineered to maximize revenue per fan.' },
          { n: '03', title: 'Weekly performance analysis', text: 'We analyze, optimize, and iterate every week to compound your growth.' },
        ].map(item => (
          <div class="bg-surface-container-lowest p-10 rounded-xl border border-outline-variant/20 flex flex-col gap-5">
            <span class="text-6xl font-black text-outline-variant/40 leading-none">{item.n}</span>
            <h4 class="text-xl font-bold text-on-surface">{item.title}</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3f. FINAL CTA (BLACK) -->
  <section class="py-32 md:py-40 bg-black text-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h3 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05]">Ready to scale your OnlyFans like this?</h3>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed">
        We only work with a limited number of creators to keep our approach hands-on and performance-driven.
      </p>
      <div>
        <a href="#apply" class="inline-block bg-white text-black font-bold px-10 py-5 rounded-xl text-sm tracking-wide hover:bg-white/90 transition-all">
          Apply Now
        </a>
      </div>
    </div>
  </section>

  <!-- 4. PROBLEM SECTION -->
  <section class="py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight">Why you're stuck</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">trending_down</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Posting but not growing</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">You're posting consistently, but nothing moves. No reach, no traction — because you don't have a real traffic system behind it.</p>
          </div>
        </div>
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">payments</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Subs aren't spending</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">You're getting subscribers... but they're not buying. Weak chatting, no structure, no strategy — money is being left on the table every day.</p>
          </div>
        </div>
        <div class="bg-surface-container-lowest p-10 rounded-xl flex flex-col gap-6 border border-outline-variant/20 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface" style="font-size:22px;">bolt</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-on-surface mb-3">Burned out doing everything</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">You're doing content, posting, replying, planning... everything. Without systems, you're not scaling — you're just working more for the same results.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SERVICES SECTION -->
  <section class="py-28 bg-surface-container">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1] mb-5">Everything that grows your income &mdash; handled for you</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed">We handle everything behind the scenes &mdash; so your page becomes a consistent revenue machine.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {[
          {
            icon: 'chat',
            title: '24/7 Monetization',
            text: 'Our in-house chatting team sells for you 24/7 &mdash; in English and Spanish &mdash; using proven strategies adapted to your personality, so you make more without being online all day.',
          },
          {
            icon: 'trending_up',
            title: 'Marketing & Growth',
            text: 'We scale your account through Instagram-focused strategies, multi-account systems, and data-driven content &mdash; bringing high-quality traffic that converts into paying fans.',
          },
          {
            icon: 'payments',
            title: 'Revenue Optimization',
            text: 'We optimize your pricing, content, and sales flow to increase how much every fan spends &mdash; turning your page into a predictable income stream.',
          },
          {
            icon: 'shield',
            title: 'DMCA & Leak Protection',
            text: 'We proactively monitor and remove leaked content while protecting your accounts &mdash; so your income stays safe as you grow.',
          },
        ].map(card => (
          <div class="bg-surface-container-lowest p-10 rounded-xl border border-outline-variant/20 hover:shadow-md transition-shadow flex flex-col gap-5">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-on-primary" style="font-size:22px;" set:html={card.icon} />
              </div>
              <h3 class="text-xl font-bold text-on-surface">{card.title}</h3>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed" set:html={card.text}></p>
          </div>
        ))}
      </div>

      <p class="text-center text-on-surface text-lg md:text-xl font-semibold mt-14">
        You focus on content. We handle everything that makes you money.
      </p>
    </div>
  </section>

  <!-- 4. WHY TOP CREATORS WORK WITH US -->
  <section class="py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">Why top creators work with us</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            icon: 'settings_suggest',
            title: 'System-driven, not guesswork',
            text: 'We don\u2019t rely on trends or luck \u2014 we plug proven systems into your account to generate consistent revenue.',
          },
          {
            icon: 'groups',
            title: 'In-house team, fully controlled',
            text: 'Our chatters, managers, and marketing team are trained and managed internally \u2014 ensuring consistency and performance.',
          },
          {
            icon: 'language',
            title: 'English & Spanish monetization',
            text: 'We sell to a global audience with native-level chatting \u2014 increasing conversions and maximizing your income.',
          },
          {
            icon: 'trending_up',
            title: 'Built for revenue, not vanity metrics',
            text: 'We focus on how much you make and how to increase it every month \u2014 not just likes or followers.',
          },
          {
            icon: 'lock_open',
            title: 'No long-term contracts',
            text: 'You stay because it works \u2014 not because you\u2019re locked in. We earn our position every month.',
          },
          {
            icon: 'tune',
            title: 'Fully adapted to you',
            text: 'Every strategy is tailored to your personality, content, and audience \u2014 no generic approaches.',
          },
        ].map(card => (
          <div class="bg-surface-container-lowest p-10 rounded-xl border border-outline-variant/20 hover:shadow-md transition-shadow flex flex-col gap-5">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-on-primary" style="font-size:22px;" set:html={card.icon} />
              </div>
              <h3 class="text-xl font-bold text-on-surface">{card.title}</h3>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed">{card.text}</p>
          </div>
        ))}
      </div>

      <p class="text-center text-on-surface text-lg md:text-xl font-semibold mt-14">
        This is not management. This is infrastructure.
      </p>
    </div>
  </section>

  <!-- 5. PROCESS SECTION -->
  <section id="how-it-works" class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight">What happens when you join</h2>
        <p class="mt-4 text-on-surface-variant text-lg max-w-xl mx-auto">A simple, fast process to start scaling your income.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-outline-variant/20">
        {[
          { num: '01', title: 'Quick evaluation', text: 'We review your account, content, and potential to identify where you can grow fastest.' },
          { num: '02', title: 'Strategy & setup', text: 'We build a custom plan and integrate our systems into your account \u2014 chatting, marketing, and monetization.' },
          { num: '03', title: 'Full system activation', text: 'We activate all growth and monetization systems inside your account \u2014 ready to scale from the start.' },
          { num: '04', title: 'Scale & optimize', text: 'We continuously optimize everything to increase your income month after month.' },
        ].map(step => (
          <div class="flex flex-col gap-4 px-8 py-10">
            <span class="text-7xl font-black text-outline-variant/30 leading-none">{step.num}</span>
            <h3 class="text-xl font-black text-on-surface">{step.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-on-surface text-lg font-semibold mt-14">
        No complexity. No wasted time. Just growth.
      </p>
    </div>
  </section>

  <!-- 6. APPLY FORM -->
  <ApplyForm lang="en" />

  <!-- 7. FAQ SECTION -->
  <section class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
      <div class="mb-14">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight">{t('home.faq.title')}</h2>
      </div>
      <div class="flex flex-col gap-3">
        {[
          { q: t('home.faq.q1'), a: t('home.faq.a1') },
          { q: t('home.faq.q2'), a: t('home.faq.a2') },
          { q: t('home.faq.q3'), a: t('home.faq.a3') },
          { q: t('home.faq.q4'), a: t('home.faq.a4') },
          { q: t('home.faq.q5'), a: t('home.faq.a5') },
          { q: t('home.faq.q6'), a: t('home.faq.a6') },
          { q: t('home.faq.q7'), a: t('home.faq.a7') },
          { q: t('home.faq.q8'), a: t('home.faq.a8') },
          { q: t('home.faq.q9'), a: t('home.faq.a9') },
          { q: t('home.faq.q10'), a: t('home.faq.a10') },
        ].map(faq => (
          <details class="bg-surface-container-low rounded-2xl group">
            <summary class="p-8 flex items-center justify-between cursor-pointer list-none select-none">
              <span class="font-semibold text-on-surface text-base pr-6">{faq.q}</span>
              <span class="material-symbols-outlined expand-icon text-on-surface-variant flex-shrink-0 transition-transform duration-300">add</span>
            </summary>
            <div class="px-8 pb-8 text-on-surface-variant text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
      </div>
    </div>
  </section>

</Layout>
