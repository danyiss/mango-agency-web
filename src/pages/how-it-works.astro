---
import Layout from '../layouts/Layout.astro';
---

<Layout title="System | MANGO Agency" activeNav="how-it-works" lang="en" transparentTop={true}>

  <!-- 1. HERO -->
  <section class="relative h-screen -mt-16 w-full bg-black flex items-center">
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full pt-16">
      <div class="max-w-[620px] flex flex-col gap-6">
        <h1 class="text-5xl md:text-7xl font-black text-white tracking-tight leading-[1.08] max-w-[560px]">
          The system<br />behind the<br />results
        </h1>
        <p class="text-white/70 text-lg md:text-xl leading-relaxed">
          A structured approach to traffic, monetization, and scaling &mdash; built for consistent growth.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. INTRO BLOCK (BLACK) -->
  <section class="py-32 md:py-40 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-6">
      <p class="text-2xl md:text-4xl font-black tracking-tight leading-[1.2]">
        Most creators focus on one thing &mdash; content, traffic, or chatting.
      </p>
      <p class="text-white/60 text-xl md:text-3xl font-bold tracking-tight leading-tight">
        That&rsquo;s why results stay inconsistent.
      </p>
      <p class="text-white text-2xl md:text-4xl font-black tracking-tight leading-[1.2] mt-4">
        We combine all three into one system.
      </p>
    </div>
  </section>

  <!-- 3. CORE SYSTEM (3 PILLARS) -->
  <section class="py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-20">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">Three pillars. One system.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {([
          { num: '01', icon: 'trending_up', title: 'Traffic', text: 'Consistent, high-quality traffic — multi-platform, built to compound.', featured: false },
          { num: '02', icon: 'payments', title: 'Monetization', text: 'Traffic converted into revenue — structured chatting, upsells, and retention. This is where the money is made.', featured: true },
          { num: '03', icon: 'tune', title: 'Optimization', text: 'Weekly performance analysis. Remove what doesn\'t work. Double down on what does.', featured: false },
        ] as const).map(p => (
          <div class={`${p.featured ? 'bg-surface-container border-accent/30' : 'bg-surface-container-lowest border-outline-variant/20'} p-10 md:p-12 rounded-2xl border flex flex-col gap-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-200 min-h-[340px]`}>
            <div class="flex items-start justify-between">
              <span class="text-6xl font-black text-on-surface/55 leading-none">{p.num}</span>
              <span class="material-symbols-outlined text-accent flex-shrink-0" style="font-size:28px;font-variation-settings:'FILL' 1;">{p.icon}</span>
            </div>
            <div class="flex flex-col gap-3 mt-auto">
              <h3 class="text-3xl md:text-4xl font-black text-on-surface tracking-tight">{p.title}</h3>
              <p class="text-on-surface-variant text-base leading-relaxed">{p.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. DIFFERENTIATION (BLACK, FULL-WIDTH) -->
  <section class="py-40 md:py-52 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-7xl font-black tracking-tight leading-[1.05]">
        Most creators do one of these well <span class="text-white/60">&mdash; we combine all three.</span>
      </h2>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed">That&rsquo;s what creates predictable revenue.</p>
    </div>
  </section>

  <!-- 5. PROCESS FLOW -->
  <section class="py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-20">
        <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-[1.1]">From audit to scale.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-outline-variant/30">
        {[
          { num: '01', title: 'Audit', text: 'We analyze your current account, traffic, and monetization.' },
          { num: '02', title: 'Build systems', text: 'We implement traffic and revenue systems tailored to your profile.' },
          { num: '03', title: 'Optimize', text: 'We track performance weekly and continuously improve results.' },
        ].map(step => (
          <div class="flex flex-col gap-5 px-0 md:px-10 py-10 first:pt-0 md:first:pt-10 md:first:pl-0 md:last:pr-0">
            <span class="text-5xl md:text-6xl font-black text-on-surface tracking-tight leading-none">{step.num}</span>
            <h3 class="text-2xl md:text-3xl font-black text-on-surface tracking-tight">{step.title}</h3>
            <p class="text-on-surface-variant text-base leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. FINAL CTA (BLACK) -->
  <section class="py-32 md:py-40 bg-black text-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center flex flex-col gap-8">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.05]">This only works when everything is aligned.</h2>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed">That&rsquo;s what we build.</p>
      <div>
        <a href="/#apply" class="inline-block bg-accent text-black font-bold px-10 py-5 rounded-[7px] text-sm tracking-wide hover:brightness-95 hover:scale-[1.02] transition-all">
          Apply Now
        </a>
      </div>
    </div>
  </section>

</Layout>
