---
interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const t = {
  en: {
    title: 'Ready to scale?',
    subtitle: 'Apply to see if you\'re a fit.',
    name: 'Stage name',
    email: 'Email',
    telegram: 'Telegram',
    telegramHint: 'We\'ll contact you here to confirm your application',
    social: 'Social media accounts',
    socialHint: 'Instagram (main + backups), TikTok, Twitter/X, Reddit. Include @ or links',
    income: 'Current monthly income (optional)',
    incomeHint: 'This helps us understand your current stage',
    submit: 'Apply now',
    privacy: 'Your data is treated confidentially.',
    reviewed: 'Applications are reviewed within 24\u201348h',
    success: 'Application sent! We\'ll reach out on Telegram within 24\u201348h.',
    error: 'Something went wrong. Try again or reach us at hello@mangova.agency',
    income0: '$0',
    income1: '$0 \u2013 $1k',
    income2: '$1k \u2013 $5k',
    income3: '$5k \u2013 $10k',
    income4: '$10k+',
    incomePlaceholder: 'Select range',
  },
  es: {
    title: '\u00bfListo para escalar?',
    subtitle: 'Aplica para ver si encajamos.',
    name: 'Nombre art\u00edstico',
    email: 'Email',
    telegram: 'Telegram',
    telegramHint: 'Te contactaremos aqu\u00ed para confirmar tu solicitud',
    social: 'Cuentas de redes sociales',
    socialHint: 'Instagram (principal + backups), TikTok, Twitter/X, Reddit. Incluye @ o links',
    income: 'Ingresos mensuales actuales (opcional)',
    incomeHint: 'Nos ayuda a entender tu etapa actual',
    submit: 'Aplicar ahora',
    privacy: 'Tus datos se tratan de forma confidencial.',
    reviewed: 'Las solicitudes se revisan en 24\u201348h',
    success: '\u00a1Solicitud enviada! Te contactaremos por Telegram en 24\u201348h.',
    error: 'Algo sali\u00f3 mal. Int\u00e9ntalo de nuevo o escr\u00edbenos a hello@mangova.agency',
    income0: '$0',
    income1: '$0 \u2013 $1k',
    income2: '$1k \u2013 $5k',
    income3: '$5k \u2013 $10k',
    income4: '$10k+',
    incomePlaceholder: 'Selecciona rango',
  },
}[lang];
---

<section id="apply" class="py-28 bg-surface px-6">
  <div class="max-w-xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-10">
      <h2 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight mb-4">{t.title}</h2>
      <p class="text-on-surface-variant text-lg">{t.subtitle}</p>
    </div>

    <!-- Form -->
    <div class="bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-8 md:p-10">
      <form id="apply-form" class="flex flex-col gap-5">
        <div>
          <label for="name" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">{t.name}</label>
          <input type="text" id="name" name="name" required
            class="w-full bg-surface-container-low border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
        </div>

        <div>
          <label for="email" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">{t.email}</label>
          <input type="email" id="email" name="email" required
            class="w-full bg-surface-container-low border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
        </div>

        <div>
          <label for="telegram" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">{t.telegram}</label>
          <input type="text" id="telegram" name="telegram" placeholder="@" required
            class="w-full bg-surface-container-low border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
          <p class="text-xs text-outline mt-1.5">{t.telegramHint}</p>
        </div>

        <div>
          <label for="social" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">{t.social} <span class="text-error">*</span></label>
          <textarea id="social" name="social" rows="3" required
            class="w-full bg-surface-container-low border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all resize-none"
            placeholder={t.socialHint}></textarea>
        </div>

        <div>
          <label for="income" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2 block">{t.income}</label>
          <select id="income" name="income"
            class="w-full bg-surface-container-low border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none cursor-pointer">
            <option value="" disabled selected>{t.incomePlaceholder}</option>
            <option value="0">{t.income0}</option>
            <option value="0-1k">{t.income1}</option>
            <option value="1k-5k">{t.income2}</option>
            <option value="5k-10k">{t.income3}</option>
            <option value="10k+">{t.income4}</option>
          </select>
          <p class="text-xs text-outline mt-1.5">{t.incomeHint}</p>
        </div>

        <button type="submit" id="submit-btn"
          class="bg-primary text-on-primary font-bold py-4 rounded-xl text-sm tracking-wide hover:bg-primary-container transition-all w-full mt-2">
          {t.submit}
        </button>

        <div class="flex items-center justify-center gap-4 text-xs text-outline">
          <span class="flex items-center gap-1">
            <span class="material-symbols-outlined" style="font-size:14px;">lock</span>
            {t.privacy}
          </span>
        </div>
        <p class="text-xs text-outline text-center">{t.reviewed}</p>
      </form>

      <!-- Success state -->
      <div id="form-success" class="hidden text-center py-12">
        <span class="material-symbols-outlined text-primary mb-4 block" style="font-size:48px;font-variation-settings:'FILL' 1;">check_circle</span>
        <p class="text-on-surface font-bold text-lg">{t.success}</p>
      </div>

      <!-- Error state -->
      <div id="form-error" class="hidden text-center py-4">
        <p class="text-error text-sm">{t.error}</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('apply-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = document.getElementById('submit-btn');
    const successEl = document.getElementById('form-success');
    const errorEl = document.getElementById('form-error');

    btn.disabled = true;
    btn.textContent = '...';
    errorEl.classList.add('hidden');

    const data = {
      name: form.name.value,
      email: form.email.value,
      telegram: form.telegram.value,
      social: form.social.value,
      income: form.income.value,
    };

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        throw new Error('Request failed');
      }
    } catch {
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = form.querySelector('[type=submit]')?.dataset?.text || 'Apply now';
    }
  });
</script>
